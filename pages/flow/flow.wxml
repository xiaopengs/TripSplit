<!-- 流水详情页 - 按日期分组的完整流水 -->
<view class="page">
  <view class="header">
    <view class="back-btn" bindtap="goBack" hover-class="hover-opacity">
      <text class="back-icon">←</text>
    </view>
    <text class="header-title">全部流水</text>
    <view class="header-placeholder"></view>
  </view>

  <scroll-view class="content safe-bottom" scroll-y enhanced show-scrollbar="{{false}}">
    <!-- 汇总卡片 -->
    <view class="summary-card">
      <text class="summary-label">总支出</text>
      <text class="summary-amount">{{totalDisplay}}</text>
      <text class="summary-count">{{billCount}} 笔记录</text>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{groupedBills.length === 0}}">
      <text class="empty-icon">📋</text>
      <text class="empty-title">暂无记录</text>
    </view>

    <!-- 日期分组列表 -->
    <view class="bill-list" wx:else>
      <block wx:for="{{groupedBills}}" wx:key="date">
        <view class="date-header">
          <text class="date-text">{{item.dateLabel}}</text>
          <text class="day-total">-{{item.totalDisplay}}</text>
        </view>

        <view 
          class="bill-item" 
          wx:for="{{item.items}}" 
          wx:for-item="bill"
          wx:key="id"
          hover-class="hover-opacity"
          bindtap="onBillTap"
          data-id="{{bill.id}}"
        >
          <view class="bill-left">
            <text class="cat-icon">{{bill.category_icon}}</text>
          </view>
          <view class="bill-middle">
            <text class="bill-name">{{bill.note || bill.category_name}}</text>
            <text class="bill-meta">{{bill.payer_name}} · {{bill.timeDisplay}}</text>
          </view>
          <text class="bill-amount">-{{bill.amountDisplay}}</text>
        </view>
      </block>
    </view>
  </scroll-view>
</view>
