/* 流水详情页样式 */
.page {
  min-height: 100vh;
  background: var(--bg-primary);
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  padding-top: calc(16rpx + env(safe-area-inset-top));
  background: white;
  margin-bottom: 20rpx;
}

.back-btn {
  width: 64rpx; height: 64rpx;
  display: flex; align-items: center; justify-content: center;
}
.back-icon { font-size: 36rpx; color: var(--text-primary); }
.header-title { font-size: 34rpx; font-weight: 600; }
.header-placeholder { width: 64rpx; }

.content { padding: 0 24rpx; }

.summary-card {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  border-radius: var(--border-radius-xl);
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-label { color: rgba(255,255,255,0.8); font-size: 26rpx; }
.summary-amount { color: white; font-size: 56rpx; font-weight: 700; margin: 8rpx 0; }
.summary-count { color: rgba(255,255,255,0.7); font-size: 24rpx; }

.empty-state {
  display: flex; flex-direction: column; align-items: center;
  padding: 120rpx 0;
}
.empty-icon { font-size: 80rpx; margin-bottom: 16rpx; opacity: 0.4; }
.empty-title { font-size: 30rpx; color: var(--text-secondary); }

.bill-list { padding-bottom: 20rpx; }

.date-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 20rpx 8rpx 12rpx;
}
.date-text { font-size: 28rpx; font-weight: 600; color: var(--text-primary); }
.day-total { font-size: 28rpx; font-weight: 600; color: var(--color-danger); }

.bill-item {
  display: flex; align-items: center;
  background: white; border-radius: var(--border-radius-md);
  padding: 24rpx; margin-bottom: 12rpx;
  box-shadow: var(--shadow-sm);
}
.bill-left { margin-right: 16rpx; }
.cat-icon { font-size: 40rpx; }
.bill-middle { flex: 1; min-width: 0; }
.bill-name { font-size: 28rpx; font-weight: 500; color: var(--text-primary); display: block; }
.bill-meta { font-size: 22rpx; color: var(--text-secondary); }
.bill-amount { font-size: 30rpx; font-weight: 600; color: var(--color-primary); flex-shrink: 0; }

.hover-opacity { opacity: 0.7; }
