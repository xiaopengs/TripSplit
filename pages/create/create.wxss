/* 创建账本页样式 */
.page {
  min-height: 100vh;
  background: var(--bg-primary);
  display: flex;
  flex-direction: column;
}

/* 头部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  padding-top: calc(16rpx + env(safe-area-inset-top));
  background: white;
}

.back-btn {
  width: 64rpx; height: 64rpx;
  display: flex; align-items: center; justify-content: center;
}

.back-icon {
  font-size: var(--font-lg);
  color: var(--text-primary);
}

.header-title {
  font-size: var(--font-lg);
  font-weight: 600;
}

.header-placeholder {
  width: 64rpx;
}

/* 表单区域 */
.form-area {
  flex: 1;
  min-width: 0;
  width: 100%;
  padding: 0 32rpx;
  padding-bottom: 200rpx;
  box-sizing: border-box;
}

/* Logo */
.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 32rpx;
}

.logo-wrap {
  width: 120rpx; height: 120rpx;
  border-radius: var(--border-radius-xl);
  display: flex; align-items: center; justify-content: center;
  box-shadow: var(--shadow-md);
  transition: background 200ms ease;
}

.logo-text {
  font-size: var(--font-xxl);
}

.logo-hint {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
  margin-top: 12rpx;
}

/* 表单项 */
.form-item {
  background: white;
  border-radius: var(--border-radius-lg);
  padding: 24rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  min-width: 0;
  box-sizing: border-box;
}

.form-label {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 12rpx;
}

.form-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
  min-width: 0;
  box-sizing: border-box;
}

.form-hint {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

/* 输入框行（input + 字数统计） */
.input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
  box-sizing: border-box;
}

.form-input {
  flex: 1;
  min-width: 0;
  padding: 20rpx 24rpx;
  background: var(--bg-primary);
  border-radius: var(--border-radius-sm);
  font-size: var(--font-md);
  box-sizing: border-box;
  height: 88rpx;
  line-height: 44rpx;
}

.char-count {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  white-space: nowrap;
  flex-shrink: 0;
}

/* Picker */
.picker-value {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  background: var(--bg-primary);
  border-radius: var(--border-radius-sm);
  font-size: var(--font-base);
  min-width: 0;
  box-sizing: border-box;
}

.picker-arrow {
  font-size: var(--font-lg);
  color: var(--text-tertiary);
}

/* 皮肤选择 */
.skin-grid {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
  margin-bottom: 8rpx;
  min-width: 0;
  box-sizing: border-box;
}

.skin-item {
  width: 80rpx; height: 80rpx;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  border: 4rpx solid transparent;
  transition: all 150ms ease;
  position: relative;
}

.skin-item.active {
  border-color: var(--text-primary);
  transform: scale(1.1);
}

.skin-check {
  color: white;
  font-size: var(--font-md);
  font-weight: bold;
}

.skin-name {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  display: block;
  text-align: center;
  margin-top: 8rpx;
}

/* 影子成员 */
.shadow-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.shadow-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  background: var(--color-shadow-bg);
  border: 1rpx solid var(--color-shadow-border);
  border-radius: 24rpx;
  font-size: var(--font-base);
  color: var(--color-shadow-text);
}

.icon-person-sm {
  width: 14px;
  height: 16px;
  position: relative;
  flex-shrink: 0;
}
.icon-person-sm::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: currentColor;
}
.icon-person-sm::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 12px;
  height: 7px;
  border-radius: 7px 7px 3px 3px;
  background: currentColor;
}

.icon-close-sm {
  width: 10px;
  height: 10px;
  position: relative;
}
.icon-close-sm::before,
.icon-close-sm::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 0;
  width: 100%;
  height: 1.5px;
  background: currentColor;
  border-radius: 1px;
}
.icon-close-sm::before { transform: translateY(-50%) rotate(45deg); }
.icon-close-sm::after { transform: translateY(-50%) rotate(-45deg); }

.shadow-remove {
  color: var(--color-shadow-text-light);
  font-size: var(--font-sm);
  width: 32rpx; height: 32rpx;
  display: flex; align-items: center; justify-content: center;
}

.add-shadow-row {
  display: flex;
  gap: 12rpx;
  align-items: center;
  width: 100%;
  min-width: 0;
  box-sizing: border-box;
}

.shadow-input {
  flex: 1;
  padding: 16rpx 20rpx;
  background: var(--bg-primary);
  border-radius: var(--border-radius-sm);
  font-size: var(--font-base);
  min-width: 0;
  height: 80rpx;
  box-sizing: border-box;
}

.add-shadow-btn {
  padding: 24rpx 32rpx;
  background: var(--color-primary);
  color: white;
  border-radius: var(--border-radius-sm);
  font-size: var(--font-base);
  font-weight: 500;
  display: flex; align-items: center; justify-content: center;
  white-space: nowrap;
  flex-shrink: 0;
}

/* 底部按钮 */
.bottom-area {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: white;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06);
}

.btn-create {
  width: 100%;
  padding: 24rpx 0;
  background: var(--color-primary);
  color: white;
  border-radius: 48rpx;
  font-size: var(--font-md);
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(52,199,89,0.35);
}

.btn-create.disabled {
  opacity: 0.5;
}
