/* 创建账本页样式 */
.page {
  min-height: 100vh;
  background: var(--bg-primary);
  display: flex;
  flex-direction: column;
}

/* 头部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  padding-top: calc(16rpx + env(safe-area-inset-top));
  background: white;
}

.back-btn {
  width: 64rpx; height: 64rpx;
  display: flex; align-items: center; justify-content: center;
}

.back-icon {
  font-size: var(--font-lg);
  color: var(--text-primary);
}

.header-title {
  font-size: var(--font-lg);
  font-weight: 600;
}

.header-placeholder {
  width: 64rpx;
}

/* 表单区域 */
.form-area {
  flex: 1;
  min-width: 0;
  width: 100%;
  padding: 24rpx 32rpx 200rpx;
  box-sizing: border-box;
}

/* 表单项 */
.form-item {
  background: white;
  border-radius: var(--border-radius-lg);
  padding: 24rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  min-width: 0;
  box-sizing: border-box;
}

.form-label {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 12rpx;
}

.form-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
  min-width: 0;
  box-sizing: border-box;
}

.form-hint {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

/* 输入框行（input + 字数统计） */
.input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
  box-sizing: border-box;
}

.form-input {
  flex: 1;
  min-width: 0;
  padding: 20rpx 24rpx;
  background: var(--bg-primary);
  border-radius: var(--border-radius-sm);
  font-size: var(--font-md);
  box-sizing: border-box;
  height: 88rpx;
  line-height: 44rpx;
}

.char-count {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  white-space: nowrap;
  flex-shrink: 0;
}

/* Picker */
.picker-value {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  background: var(--bg-primary);
  border-radius: var(--border-radius-sm);
  font-size: var(--font-base);
  min-width: 0;
  box-sizing: border-box;
}

.picker-arrow {
  font-size: var(--font-lg);
  color: var(--text-tertiary);
}

/* ============================================
   视觉风格行（图标预览 + 背景色选择）
   ============================================ */
.visual-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.visual-hint {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

.visual-row {
  display: flex;
  align-items: center;
}

/* 左侧：图标预览（点击换图标） */
.visual-preview {
  width: 76rpx;
  height: 76rpx;
  border-radius: var(--border-radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.visual-preview-icon {
  font-size: 44rpx;
  line-height: 1;
}

/* 右侧：背景色选择 */
.visual-colors {
  flex: 1;
  min-width: 0;
  display: flex;
  margin-left: 64rpx;
  justify-content: space-between;
}

.visual-color-dot {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  transition: all 150ms ease;
}

.visual-color-dot.active {
  transform: scale(1.3);
  box-shadow: 0 0 0 5rpx rgba(255,255,255,0.9), 0 6rpx 16rpx rgba(0,0,0,0.18);
}

/* 图标选择面板 */
.icon-picker-mask {
  margin-top: 20rpx;
  background: var(--bg-primary);
  border-radius: var(--border-radius-md);
  padding: 20rpx;
}

.icon-picker {
  display: grid;
  grid-template-columns: repeat(8, 1fr);
  gap: 12rpx;
}

.icon-picker-item {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--border-radius-sm);
  font-size: 40rpx;
  background: white;
  transition: all 150ms ease;
}

.icon-picker-item.selected {
  border-radius: var(--border-radius-md);
  transform: scale(1.08);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.12);
}

/* 影子成员 */
.shadow-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.shadow-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  background: var(--color-shadow-bg);
  border: 1rpx solid var(--color-shadow-border);
  border-radius: 24rpx;
  font-size: var(--font-base);
  color: var(--color-shadow-text);
}

.icon-person-sm {
  width: 14px;
  height: 16px;
  position: relative;
  flex-shrink: 0;
}
.icon-person-sm::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--color-shadow-text);
}
.icon-person-sm::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 12px;
  height: 7px;
  border-radius: 7px 7px 3px 3px;
  background: var(--color-shadow-text);
}

.shadow-remove {
  color: var(--color-shadow-text-light);
  font-size: var(--font-sm);
  width: 32rpx; height: 32rpx;
  display: flex; align-items: center; justify-content: center;
}

.add-shadow-row {
  display: flex;
  gap: 12rpx;
  align-items: center;
  width: 100%;
  min-width: 0;
  box-sizing: border-box;
}

.shadow-input {
  flex: 1;
  padding: 16rpx 20rpx;
  background: var(--bg-primary);
  border-radius: var(--border-radius-sm);
  font-size: var(--font-base);
  min-width: 0;
  height: 80rpx;
  box-sizing: border-box;
}

.add-shadow-btn {
  padding: 24rpx 32rpx;
  background: var(--color-primary);
  color: white;
  border-radius: var(--border-radius-sm);
  font-size: var(--font-base);
  font-weight: 500;
  display: flex; align-items: center; justify-content: center;
  white-space: nowrap;
  flex-shrink: 0;
}

/* 底部按钮 */
.bottom-area {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: white;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06);
}

.btn-create {
  width: 100%;
  padding: 24rpx 0;
  background: var(--color-primary);
  color: white;
  border-radius: 48rpx;
  font-size: var(--font-md);
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(52,199,89,0.35);
}

.btn-create.disabled {
  opacity: 0.5;
}
