<!-- 创建账本页 -->
<view class="page">
  <view class="header">
    <view class="back-btn" bindtap="goBack" hover-class="hover-opacity">
      <view class="icon-back"></view>
    </view>
    <text class="header-title">新建账本</text>
    <view class="header-placeholder"></view>
  </view>

  <scroll-view class="form-area" scroll-y enhanced show-scrollbar="{{false}}">
    <!-- 账本名称 -->
    <view class="form-item">
      <text class="form-label">账本名称</text>
      <view class="input-row">
        <input
          class="form-input"
          placeholder="例如：曼谷大吃大喝之旅"
          value="{{bookName}}"
          bindinput="onNameInput"
          maxlength="20"
          focus="{{true}}"
        />
        <text class="char-count">{{bookName.length}}/20</text>
      </view>
    </view>

    <!-- 视觉风格：图标 + 背景色 一行搞定 -->
    <view class="form-item">
      <view class="visual-header">
        <text class="form-label">视觉风格</text>
        <text class="visual-hint">点击图标、颜色可更换</text>
      </view>
      <view class="visual-row">
        <view class="visual-preview" style="background: {{selectedSkinColor}}" bindtap="onLogoTap" hover-class="hover-opacity">
          <text class="visual-preview-icon">{{logoIcons[logoIndex]}}</text>
        </view>
        <view class="visual-colors">
          <view
            class="visual-color-dot {{selectedSkinIndex === index ? 'active' : ''}}"
            wx:for="{{skinColors}}" wx:key="value"
            bindtap="onSkinTap"
            data-index="{{index}}"
            data-color="{{item.value}}"
            style="background: {{item.value}}"
          ></view>
        </view>
      </view>
      <!-- 图标选择面板 -->
      <view class="icon-picker-mask" wx:if="{{showIconPicker}}" bindtap="closeIconPicker">
        <view class="icon-picker" catchtap="">
          <view
            class="icon-picker-item {{logoIndex === index ? 'selected' : ''}}"
            wx:for="{{logoIcons}}" wx:key="index"
            bindtap="onSelectIcon"
            data-index="{{index}}"
            style="{{logoIndex === index ? 'background: ' + selectedSkinColor : ''}}"
          >
            <text>{{item}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 你的称呼 -->
    <view class="form-item">
      <view class="form-row">
        <text class="form-label">你的称呼</text>
        <text class="form-hint">其他人会看到这个名字</text>
      </view>
      <view class="input-row">
        <input
          class="form-input"
          type="nickname"
          placeholder="点击获取微信昵称"
          value="{{creatorNickname}}"
          bindinput="onNicknameInput"
          maxlength="20"
        />
      </view>
    </view>

    <!-- 币种选择 -->
    <view class="form-item">
      <text class="form-label">默认币种</text>
      <picker
        mode="selector"
        range="{{currencies}}"
        range-key="display"
        value="{{currencyIndex}}"
        bindchange="onCurrencyChange"
      >
        <view class="picker-value">
          <text>{{currencies[currencyIndex].flag}} {{currencies[currencyIndex].name}} ({{currencies[currencyIndex].symbol}})</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 开始日期 -->
    <view class="form-item">
      <text class="form-label">开始日期</text>
      <picker
        mode="date"
        value="{{startDate}}"
        bindchange="onDateChange"
      >
        <view class="picker-value">
          <text>{{startDate}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 影子成员 -->
    <view class="form-item">
      <view class="form-row">
        <text class="form-label">影子成员</text>
        <text class="form-hint">可先预设成员，后期扫码认领</text>
      </view>

      <!-- 已添加的影子成员 -->
      <view class="shadow-list">
        <view class="shadow-tag" wx:for="{{shadowMembers}}" wx:key="index">
          <view class="icon-person-sm"></view><text>{{item}}</text>
          <text class="shadow-remove" data-index="{{index}}" catchtap="removeShadow">✕</text>
        </view>
      </view>

      <!-- 添加输入 -->
      <view class="add-shadow-row">
        <input
          class="shadow-input"
          placeholder="输入成员名称"
          value="{{newShadowName}}"
          bindinput="onShadowInput"
          bindconfirm="addShadowMember"
          maxlength="10"
        />
        <view class="add-shadow-btn" bindtap="addShadowMember" hover-class="hover-opacity">
          <text>+ 添加</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 底部创建按钮 -->
  <view class="bottom-area">
    <button 
      class="btn-create {{canCreate ? '' : 'disabled'}}"
      bindtap="onCreate"
      disabled="{{!canCreate}}"
    >创建账本</button>
  </view>
</view>
