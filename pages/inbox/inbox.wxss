/* 待整理收件箱页样式 */
.page { min-height: 100vh; background: var(--bg-primary); }

.header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16rpx 24rpx;
  padding-top: calc(16rpx + env(safe-area-inset-top));
  background: white; margin-bottom: 20rpx;
}
.back-btn { width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; }
.back-icon { font-size: var(--font-lg); color: var(--text-primary); }
.header-title { font-size: var(--font-lg); font-weight: 600; }
.header-badge {
  min-width: 40rpx; height: 40rpx; background: var(--color-danger); color: white;
  border-radius: 20rpx; display: flex; align-items: center; justify-content: center;
  font-size: var(--font-sm); padding: 0 12rpx;
}
.header-placeholder { width: 64rpx; }

.content { padding: 0 24rpx; }

.tip-banner {
  padding: 16rpx 24rpx; background: rgba(52,199,89,0.08);
  border-radius: var(--border-radius-md); margin-bottom: 20rpx;
  font-size: var(--font-sm); color: var(--text-secondary);
}

.inbox-list { padding-bottom: 20rpx; }

.inbox-item {
  display: flex; background: white; border-radius: var(--border-radius-lg);
  padding: 24rpx; margin-bottom: 16rpx; box-shadow: var(--shadow-sm);
}

.item-thumb {
  width: 140rpx; height: 140rpx; border-radius: var(--border-radius-md);
  margin-right: 20rpx; flex-shrink: 0;
}

.item-info { flex: 1; display: flex; flex-direction: column; justify-content: center; }

.status-processing, .status-error {
  display: flex; align-items: center; gap: 12rpx;
}
.spinner { font-size: var(--font-md); }
.status-text { font-size: var(--font-base); color: var(--text-secondary); }
.status-error .status-text { color: var(--color-danger); }

.btn-retry {
  background: var(--color-info) !important; color: white !important;
  font-size: var(--font-sm) !important; padding: 4rpx 20rpx !important;
  border-radius: 24rpx !important;
}

.result-pending { display: flex; flex-direction: column; }

.result-top { display: flex; align-items: center; gap: 12rpx; margin-bottom: 6rpx; }

.result-amount {
  font-size: 40rpx; font-weight: 700; color: var(--color-primary);
}
.result-amount.uncertain { color: var(--color-danger); }

.confidence-badge {
  font-size: 18rpx; padding: 2rpx 12rpx; border-radius: 10rpx;
}
.confidence-badge.high { background: rgba(52,199,89,0.1); color: var(--color-success); }
.confidence-badge.low { background: rgba(255,59,48,0.1); color: var(--color-danger); }

.result-category { font-size: var(--font-sm); color: var(--text-secondary); }
.result-note { font-size: var(--font-sm); color: var(--text-tertiary); margin-top: 2rpx; }

.result-actions { display: flex; gap: 12rpx; margin-top: 12rpx; }
.btn-confirm {
  background: var(--color-primary) !important; color: white !important;
  font-size: var(--font-sm) !important; padding: 4rpx 20rpx !important; border-radius: 24rpx !important;
}
.btn-edit {
  background: var(--bg-primary) !important; color: var(--text-primary) !important;
  font-size: var(--font-sm) !important; padding: 4rpx 20rpx !important; border-radius: 24rpx !important;
}
.btn-reject {
  background: #FFF0F0 !important; color: var(--color-danger) !important;
  font-size: var(--font-sm) !important; padding: 4rpx 20rpx !important; border-radius: 24rpx !important;
}
