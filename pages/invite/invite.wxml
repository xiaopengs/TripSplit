<!-- 邀请加入页面 -->
<view class="page">

  <!-- 加载中 -->
  <view class="state-wrap" wx:if="{{loading}}">
    <view class="icon-spinner"></view>
    <text class="state-text">加载中...</text>
  </view>

  <!-- 错误状态 -->
  <view class="state-wrap" wx:elif="{{error}}">
    <view class="icon-error-circle"></view>
    <text class="state-title">无法加入</text>
    <text class="state-desc">{{error}}</text>
    <view class="btn-home" bindtap="onGoHome" hover-class="hover-opacity">
      <text>返回首页</text>
    </view>
  </view>

  <!-- 已加入 -->
  <view class="state-wrap" wx:elif="{{joined}}">
    <view class="icon-success-circle"></view>
    <text class="state-title">已加入「{{bookName}}」</text>
    <text class="state-desc">快去和朋友们一起记账吧</text>
    <view class="btn-home" bindtap="onGoHome" hover-class="hover-opacity">
      <text>进入账本</text>
    </view>
  </view>

  <!-- 邀请内容 (share 模式) -->
  <view class="invite-content" wx:elif="{{mode === 'share'}}">
    <!-- 账本信息 -->
    <view class="book-card">
      <view class="book-icon"><view class="icon-notebook"></view></view>
      <view class="book-info">
        <text class="book-name">{{bookName}}</text>
        <text class="book-meta">{{memberCount}} 位成员</text>
      </view>
    </view>

    <!-- 选择身份 -->
    <view class="section">
      <text class="section-label">选择你的身份</text>
      <view class="shadow-list">
        <!-- 影子成员选项 -->
        <view
          class="shadow-item {{selectedShadowId === item._id ? 'selected' : ''}}"
          wx:for="{{unclaimedShadows}}"
          wx:key="_id"
          bindtap="onSelectShadow"
          data-id="{{item._id}}"
        >
          <view class="shadow-avatar">
            <view class="icon-person"></view>
          </view>
          <view class="shadow-body">
            <text class="shadow-name">{{item.shadow_name}}</text>
            <text class="shadow-hint">认领此身份</text>
          </view>
          <view class="check-mark" wx:if="{{selectedShadowId === item._id}}">✓</view>
        </view>

        <!-- 以自己名称加入选项 -->
        <view
          class="shadow-item self-item {{joinMode === 'self' ? 'selected' : ''}}"
          bindtap="onSelectSelf"
        >
          <view class="shadow-avatar self-avatar">
            <view class="icon-smile"></view>
          </view>
          <view class="shadow-body">
            <text class="shadow-name">以自己名称加入</text>
            <text class="shadow-hint">使用微信昵称作为新成员</text>
          </view>
          <view class="check-mark" wx:if="{{joinMode === 'self'}}">✓</view>
        </view>
      </view>
    </view>

    <!-- 你的称呼 -->
    <view class="section">
      <text class="section-label">你的称呼</text>
      <input
        class="nickname-input"
        type="nickname"
        placeholder="点击获取微信昵称（选填）"
        value="{{myNickname}}"
        bindinput="onNicknameInput"
        maxlength="20"
      />
    </view>

    <!-- 操作按钮 -->
    <view class="action-area">
      <view
        class="btn-join {{!joinMode ? 'disabled' : ''}}"
        bindtap="onJoin"
        hover-class="{{joinMode ? 'hover-opacity' : ''}}"
      >
        <text>{{joining ? '加入中...' : (joinMode === 'shadow' ? '认领并加入' : '加入账本')}}</text>
      </view>
    </view>
  </view>

</view>
