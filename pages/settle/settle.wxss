/* 结算中心页样式 */
.page { min-height: 100vh; background: var(--bg-primary); }

.header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16rpx 24rpx; padding-top: calc(16rpx + env(safe-area-inset-top));
  background: white; margin-bottom: 20rpx;
}
.back-btn { width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; }
.back-icon { font-size: 36rpx; color: var(--text-primary); }
.header-title { font-size: 34rpx; font-weight: 600; }
.header-placeholder { width: 64rpx; }

.content { padding: 0 24rpx; }

.empty-state {
  display: flex; flex-direction: column; align-items: center; padding: 120rpx 0;
}
.empty-icon { font-size: 80rpx; margin-bottom: 16rpx; opacity: 0.4; }
.empty-title { font-size: 32rpx; font-weight: 600; color: var(--text-primary); margin-bottom: 8rpx; }
.empty-desc { font-size: 26rpx; color: var(--text-secondary); }

.settle-view { padding-bottom: 20rpx; }

.summary-card {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  border-radius: var(--border-radius-xl); padding: 40rpx 32rpx; margin-bottom: 24rpx;
}
.summary-title {
  color: white; font-size: 36rpx; font-weight: 700; display: block; text-align: center;
}
.summary-optimized {
  color: rgba(255,255,255,0.75); font-size: 24rpx; display: block; text-align: center; margin: 8rpx 0 24rpx;
}

.summary-stats {
  display: flex; justify-content: space-around;
}
.stat-item { display: flex; flex-direction: column; align-items: center; }
.stat-value { color: white; font-size: 32rpx; font-weight: 700; }
.stat-label { color: rgba(255,255,255,0.7); font-size: 22rpx; margin-top: 4rpx; }

.setting-row {
  display: flex; justify-content: space-between; align-items: center;
  background: white; border-radius: var(--border-radius-md); padding: 24rpx;
  margin-bottom: 24rpx;
}
.setting-label { font-size: 28rpx; color: var(--text-primary); }

.transfer-list { padding-bottom: 20rpx; }

.transfer-card {
  background: white; border-radius: var(--border-radius-xl); padding: 36rpx 28rpx;
  margin-bottom: 20rpx; box-shadow: var(--shadow-sm);
}

.transfer-header {
  display: flex; align-items: center; justify-content: space-between;
}

.person { display: flex; flex-direction: column; align-items: center; flex: 1; }
.person-avatar {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  background: var(--bg-primary); color: var(--text-primary);
  display: flex; align-items: center; justify-content: center;
  font-size: 30rpx; font-weight: 600; margin-bottom: 8rpx;
}
.person-avatar.receive { background: rgba(52,199,89,0.15); color: var(--color-primary); }
.person-name { font-size: 28rpx; font-weight: 600; color: var(--text-primary); }
.person-role { font-size: 20rpx; color: var(--text-tertiary); margin-top: 2rpx; }

.arrow-circle {
  width: 64rpx; height: 64rpx; border-radius: 50%;
  background: var(--color-primary); color: white;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; font-weight: bold; flex-shrink: 0;
}

.transfer-amount {
  display: block; text-align: center;
  font-size: 52rpx; font-weight: 700; color: var(--color-primary);
  margin: 28rpx 0;
}

.transfer-actions {
  display: flex; gap: 16rpx; justify-content: center;
}
.action-btn {
  flex: 1; text-align: center; padding: 16rpx 0; border-radius: 40rpx; font-size: 26rpx;
}
.action-btn.paid { background: #F2F2F7; color: var(--text-primary); }
.action-btn.forgive { border: 2rpx solid var(--color-primary); color: var(--color-primary); background: transparent; }

.status-text {
  flex: 1; text-align: center; padding: 16rpx 0; font-size: 26rpx;
}
.status-text.done { color: var(--color-success); font-weight: 500; }
.status-text.forgiven { color: var(--text-tertiary); }

.footer-tip {
  text-align: center; padding: 24rpx 0; font-size: 22rpx; color: var(--text-tertiary);
}

.hover-opacity { opacity: 0.7; }
