/* 结算中心页样式 */
.page { min-height: 100vh; background: var(--bg-primary); }

.header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16rpx 24rpx; padding-top: calc(16rpx + env(safe-area-inset-top));
  background: white; margin-bottom: 20rpx;
}
.back-btn { width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; }
.back-icon { font-size: var(--font-lg); color: var(--text-primary); }
.header-title { font-size: var(--font-lg); font-weight: 600; }
.header-placeholder { width: 64rpx; }

.content { padding: 0 24rpx; }
.settle-view { padding-bottom: 20rpx; }

/* 汇总卡片 */
.summary-card {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  border-radius: var(--border-radius-xl); padding: 36rpx 32rpx; margin-bottom: 24rpx;
}
.summary-title {
  color: white; font-size: var(--font-lg); font-weight: 700; display: block; text-align: center;
}
.summary-optimized {
  color: rgba(255,255,255,0.75); font-size: var(--font-sm); display: block; text-align: center; margin-top: 8rpx;
}

/* 抹零开关 */
.setting-row {
  display: flex; justify-content: space-between; align-items: center;
  background: white; border-radius: var(--border-radius-md); padding: 24rpx; margin-bottom: 24rpx;
}
.setting-label { font-size: var(--font-base); color: var(--text-primary); }

/* 转账卡片 */
.transfer-list { padding-bottom: 20rpx; }

.transfer-card {
  background: white; border-radius: var(--border-radius-xl); padding: 36rpx 28rpx;
  margin-bottom: 20rpx; box-shadow: var(--shadow-sm);
}
.transfer-card.card-done { opacity: 0.7; }

.transfer-header {
  display: flex; align-items: center; justify-content: space-between;
}

.person { display: flex; flex-direction: column; align-items: center; flex: 1; }
.person-avatar {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  background: var(--bg-primary); color: var(--text-primary);
  display: flex; align-items: center; justify-content: center;
  font-size: var(--font-md); font-weight: 600; margin-bottom: 8rpx;
}
.person-avatar.receive { background: rgba(52,199,89,0.15); color: var(--color-primary); }
.person-name { font-size: var(--font-base); font-weight: 600; color: var(--text-primary); }
.person-role { font-size: var(--font-xs); color: var(--text-tertiary); margin-top: 2rpx; }

.arrow-circle {
  width: 64rpx; height: 64rpx; border-radius: 50%;
  background: var(--color-primary); color: white;
  display: flex; align-items: center; justify-content: center;
  font-size: var(--font-base); font-weight: bold; flex-shrink: 0;
}

/* 每张卡片的金额行 */
.amount-row {
  display: flex; align-items: center; justify-content: space-between;
  margin: 24rpx 0 8rpx;
  padding: 20rpx 24rpx;
  background: var(--bg-primary);
  border-radius: var(--border-radius-md);
}
.amount-info { display: flex; flex-direction: column; }
.amount-total-label { font-size: var(--font-xs); color: var(--text-tertiary); }
.amount-total-value { font-size: var(--font-lg); font-weight: 700; color: var(--text-primary); }

.amount-settled-hint {
  font-size: var(--font-xs);
  color: var(--color-success);
  margin-top: 4rpx;
}

.amount-pending, .amount-settled { display: flex; flex-direction: column; align-items: flex-end; }
.pending-label, .settled-label, .forgiven-label { font-size: var(--font-xs); color: var(--text-tertiary); }
.pending-value { font-size: var(--font-lg); font-weight: 700; color: var(--color-primary); }
.settled-value { font-size: var(--font-lg); font-weight: 700; color: var(--color-success); }
.forgiven-value { font-size: var(--font-lg); font-weight: 700; color: var(--text-tertiary); }

/* 操作按钮 */
.transfer-actions {
  display: flex; gap: 16rpx; justify-content: center;
}
.action-btn {
  flex: 1; text-align: center; padding: 16rpx 0; border-radius: 40rpx; font-size: var(--font-base);
}
.action-btn.paid { background: #F2F2F7; color: var(--text-primary); }
.action-btn.forgive { border: 2rpx solid var(--color-primary); color: var(--color-primary); background: transparent; }

/* 已处理状态行 */
.transfer-status {
  display: flex; align-items: center; justify-content: center; gap: 24rpx;
}
.status-tag {
  font-size: var(--font-base); font-weight: 500;
  padding: 12rpx 32rpx; border-radius: 32rpx;
}
.status-paid { color: var(--color-success); background: rgba(52,199,89,0.1); }
.status-forgiven { color: var(--text-tertiary); background: var(--bg-primary); }

.undo-btn {
  font-size: var(--font-sm); color: var(--text-secondary);
  padding: 8rpx 20rpx; border: 1rpx solid var(--border-color);
  border-radius: 24rpx;
}

/* 底部重置按钮 */
.footer-area { padding: 0 0 12rpx; }
.reset-all-btn {
  text-align: center; padding: 20rpx 0;
  color: var(--color-danger); font-size: var(--font-base);
  border-radius: var(--border-radius-lg);
  background: var(--bg-danger-tint);
}

.footer-tip {
  text-align: center; padding: 24rpx 0; font-size: var(--font-sm); color: var(--text-tertiary);
}

.hover-opacity { opacity: 0.7; }
