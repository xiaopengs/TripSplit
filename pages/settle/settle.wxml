<!-- 结算中心页面 -->
<view class="page">
  <view class="header">
    <view class="back-btn" bindtap="goBack" hover-class="hover-opacity">
      <view class="icon-back"></view>
    </view>
    <text class="header-title">结算中心</text>
    <view class="header-placeholder"></view>
  </view>

  <scroll-view class="content" scroll-y enhanced show-scrollbar="{{false}}" refresher-enabled="{{true}}" refresher-triggered="{{refreshing}}" bindrefresherrefresh="onRefresh">
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!result || result.transfers.length === 0}}">
      <view class="empty-icon-large icon-empty-settle"></view>
      <text class="empty-title">暂无结算数据</text>
      <text class="empty-desc">记录更多开销后即可查看结算方案</text>
    </view>

    <!-- 结算方案 -->
    <view class="settle-view" wx:else>
      <!-- 汇总卡片 -->
      <view class="summary-card">
        <text class="summary-title">智能结算方案</text>
        <text class="summary-optimized">已优化为最少转账（{{result.totalTransfers}}笔）· {{result.memberCount}}人参与</text>
      </view>

      <!-- 抹零开关 -->
      <view class="setting-row">
        <text class="setting-label">抹零结算</text>
        <switch checked="{{roundToYuan}}" bindchange="onRoundToggle" color="#34C759" />
      </view>

      <!-- 转账建议列表 -->
      <view class="transfer-list">
        <view class="transfer-card" wx:for="{{result.transfers}}" wx:key="id" bindtap="onTransferTap" data-index="{{index}}">
          <!-- 人物信息 -->
          <view class="transfer-header">
            <view class="person from-person">
              <view class="person-avatar">{{item.from_char}}</view>
              <text class="person-name">{{item.from_name}}</text>
              <text class="person-role">付款</text>
            </view>

            <view class="arrow-circle">
              <view class="icon-arrow-right"></view>
            </view>

            <view class="person to-person">
              <view class="person-avatar receive">{{item.to_char}}</view>
              <text class="person-name">{{item.to_name}}</text>
              <text class="person-role">收款</text>
            </view>
          </view>

          <!-- 金额 -->
          <view class="amount-row">
            <text class="amount-value">{{item.amountDisplay}}</text>
          </view>
        </view>
      </view>

      <!-- 底部提示 -->
      <view class="footer-tip">
        <text>下拉可刷新同步最新数据</text>
      </view>
    </view>
  </scroll-view>

  <!-- 结算明细弹窗 -->
  <settle-detail-popup
    visible="{{settleDetailVisible}}"
    detail="{{settleDetailData}}"
    bind:onclose="closeSettleDetail"
  />
</view>
