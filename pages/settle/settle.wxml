<!-- 结算中心页面 -->
<view class="page">
  <view class="header">
    <view class="back-btn" bindtap="goBack" hover-class="hover-opacity">
      <text class="back-icon">←</text>
    </view>
    <text class="header-title">结算中心</text>
    <view class="header-placeholder"></view>
  </view>

  <scroll-view class="content safe-bottom" scroll-y enhanced show-scrollbar="{{false}}">
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!result || result.transfers.length === 0}}">
      <text class="empty-icon">🧮</text>
      <text class="empty-title">暂无结算数据</text>
      <text class="empty-desc">记录更多开销后即可查看结算方案</text>
    </view>

    <!-- 结算方案 -->
    <view class="settle-view" wx:else>
      <!-- 汇总 -->
      <view class="summary-card">
        <text class="summary-title">智能结算方案</text>
        <text class="summary-optimized">已优化为最少转账（{{result.totalTransfers}}笔）</text>
        <view class="summary-stats">
          <view class="stat-item">
            <text class="stat-value">{{result.memberCount}}</text>
            <text class="stat-label">参与人数</text>
          </view>
          <view class="stat-item">
            <text class="stat-value">{{result.billCount}}</text>
            <text class="stat-label">总记录数</text>
          </view>
          <view class="stat-item">
            <text class="stat-value">{{result.totalAmountDisplay}}</text>
            <text class="stat-label">总流水</text>
          </view>
        </view>
      </view>

      <!-- 抹零开关 -->
      <view class="setting-row">
        <text class="setting-label">抹零结算</text>
        <switch 
          checked="{{roundToYuan}}" 
          bindchange="onRoundToggle" 
          color="#34C759"
        />
      </view>

      <!-- 转账建议列表 -->
      <view class="transfer-list">
        <view class="transfer-card" wx:for="{{result.transfers}}" wx:key="id">
          <view class="transfer-header">
            <view class="person from-person">
              <view class="person-avatar">{{item.from_name[0]}}</view>
              <text class="person-name">{{item.from_name}}</text>
              <text class="person-role">付款</text>
            </view>
            
            <view class="arrow-circle">
              <text>→</text>
            </view>
            
            <view class="person to-person">
              <view class="person-avatar receive">{{item.to_name[0]}}</view>
              <text class="person-name">{{item.to_name}}</text>
              <text class="person-role">收款</text>
            </view>
          </view>

          <text class="transfer-amount">{{item.amountDisplay}}</text>

          <view class="transfer-actions">
            <view 
              class="action-btn paid {{item.status === 'paid' ? 'done' : ''}}" 
              wx:if="{{item.status !== 'paid' && item.status !== 'forgiven'}}"
              bindtap="onMarkPaid" data-index="{{index}}"
            >标记已付</view>
            <text class="status-text done" wx:if="{{item.status === 'paid'}}">✓ 已付款</text>

            <view 
              class="action-btn forgive" 
              wx:if="{{item.status !== 'forgiven' && item.status !== 'paid'}}"
              bindtap="onForgive" data-index="{{index}}"
            >下顿他请</view>
            <text class="status-text forgiven" wx:if="{{item.status === 'forgiven'}}">已被免除</text>
          </view>
        </view>
      </view>

      <!-- 底部提示 -->
      <view class="footer-tip">
        <text>💡 系统自动对冲中间环节，生成最优转账方案</text>
      </view>
    </view>
  </scroll-view>
</view>
