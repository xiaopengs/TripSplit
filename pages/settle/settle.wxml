<!-- 结算中心页面 -->
<view class="page">
  <view class="header">
    <view class="back-btn" bindtap="goBack" hover-class="hover-opacity">
      <text class="back-icon">←</text>
    </view>
    <text class="header-title">结算中心</text>
    <view class="header-placeholder"></view>
  </view>

  <scroll-view class="content safe-bottom" scroll-y enhanced show-scrollbar="{{false}}">
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!result || result.transfers.length === 0}}">
      <text class="empty-emoji">🧮</text>
      <text class="empty-title">暂无结算数据</text>
      <text class="empty-desc">记录更多开销后即可查看结算方案</text>
    </view>

    <!-- 结算方案 -->
    <view class="settle-view" wx:else>
      <!-- 汇总卡片：仅显示笔数和人数 -->
      <view class="summary-card">
        <text class="summary-title">智能结算方案</text>
        <text class="summary-optimized">已优化为最少转账（{{result.totalTransfers}}笔）· {{result.memberCount}}人参与</text>
      </view>

      <!-- 抹零开关 -->
      <view class="setting-row">
        <text class="setting-label">抹零结算</text>
        <switch checked="{{roundToYuan}}" bindchange="onRoundToggle" color="#34C759" />
      </view>

      <!-- 转账建议列表 -->
      <view class="transfer-list">
        <view class="transfer-card {{item.status !== 'pending' ? 'card-done' : ''}}" wx:for="{{result.transfers}}" wx:key="id">
          <!-- 人物信息 -->
          <view class="transfer-header">
            <view class="person from-person">
              <view class="person-avatar">{{item.from_char}}</view>
              <text class="person-name">{{item.from_name}}</text>
              <text class="person-role">付款</text>
            </view>

            <view class="arrow-circle">
              <text>→</text>
            </view>

            <view class="person to-person">
              <view class="person-avatar receive">{{item.to_char}}</view>
              <text class="person-name">{{item.to_name}}</text>
              <text class="person-role">收款</text>
            </view>
          </view>

          <!-- 金额行：总金额 + 待结算金额 -->
          <view class="amount-row">
            <view class="amount-info">
              <text class="amount-total-label">结算金额</text>
              <text class="amount-total-value">{{item.amountDisplay}}</text>
              <text class="amount-settled-hint" wx:if="{{item.settledAmount > 0 && item.pendingAmount > 0}}">已结 {{item.settledAmountDisplay}}</text>
            </view>
            <view class="amount-pending" wx:if="{{item.status === 'pending'}}">
              <text class="pending-label">待结算</text>
              <text class="pending-value">{{item.pendingAmountDisplay}}</text>
            </view>
            <view class="amount-settled" wx:elif="{{item.status === 'paid'}}">
              <text class="settled-label">已结算</text>
              <text class="settled-value">{{item.amountDisplay}}</text>
            </view>
            <view class="amount-settled" wx:elif="{{item.status === 'forgiven'}}">
              <text class="forgiven-label">已免除</text>
              <text class="forgiven-value">{{item.amountDisplay}}</text>
            </view>
          </view>

          <!-- pending 状态：操作按钮 -->
          <view class="transfer-actions" wx:if="{{item.status === 'pending'}}">
            <view class="action-btn paid" bindtap="onMarkPaid" data-index="{{index}}" hover-class="hover-opacity">标记已付</view>
            <view class="action-btn forgive" bindtap="onForgive" data-index="{{index}}" hover-class="hover-opacity">下顿他请</view>
          </view>

          <!-- paid/forgiven 状态：状态标签 + 撤销 -->
          <view class="transfer-status" wx:if="{{item.status === 'paid'}}">
            <text class="status-tag status-paid">✓ 已付款</text>
            <view class="undo-btn" bindtap="onUndo" data-index="{{index}}" hover-class="hover-opacity">撤销</view>
          </view>

          <view class="transfer-status" wx:if="{{item.status === 'forgiven'}}">
            <text class="status-tag status-forgiven">已被免除</text>
            <view class="undo-btn" bindtap="onUndo" data-index="{{index}}" hover-class="hover-opacity">撤销</view>
          </view>
        </view>
      </view>

      <!-- 底部操作区 -->
      <view class="footer-area" wx:if="{{result.settledCount > 0}}">
        <view class="reset-all-btn" bindtap="onResetAll" hover-class="hover-opacity">
          <text>重置所有结算状态</text>
        </view>
      </view>

      <!-- 底部提示 -->
      <view class="footer-tip">
        <text>💡 新增记账后，已结算状态会自动重置</text>
      </view>
    </view>
  </scroll-view>
</view>
