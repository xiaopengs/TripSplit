/* ============================================
   TripSplit - 账本管理页样式
   ============================================ */

.page-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: var(--bg-primary);
}

/* ============================================
   自定义导航栏
   ============================================ */

.page-header {
  flex-shrink: 0;
  background: var(--bg-card);
}

.header-row {
  display: flex;
  align-items: center;
  padding: 0 32rpx 24rpx;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 44rpx;
  color: var(--text-primary);
  font-weight: 300;
  line-height: 1;
}

.header-title {
  flex: 1;
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
  margin-left: 8rpx;
}

.header-right {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
}

.sort-text {
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

.sort-arrow {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  margin-left: 4rpx;
}

/* ============================================
   筛选 Tab
   ============================================ */

.filter-tabs {
  display: flex;
  padding: 16rpx 32rpx 20rpx;
  gap: 24rpx;
}

.filter-tab {
  font-size: var(--font-base);
  color: var(--text-secondary);
  padding: 8rpx 0;
  position: relative;
}

.filter-tab.active {
  color: var(--text-primary);
  font-weight: 600;
}

.filter-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: var(--color-primary);
}

/* ============================================
   内容区域
   ============================================ */

.content-area {
  flex: 1;
  height: 0;
}

/* ============================================
   账本卡片列表
   ============================================ */

.book-list {
  padding: 0 24rpx 180rpx;
}

.book-card {
  display: flex;
  background: var(--bg-card);
  border-radius: var(--border-radius-lg);
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
  overflow: hidden;
  transition: opacity 150ms ease;
}

.book-card:active {
  opacity: 0.85;
}

/* 左侧颜色条 */
.card-accent {
  width: 8rpx;
  flex-shrink: 0;
}

/* 卡片主体 */
.card-body {
  flex: 1;
  padding: 28rpx 28rpx 24rpx;
  min-width: 0;
}

/* 名称 + 当前标记 */
.card-top {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-name {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.current-badge {
  font-size: var(--font-sm);
  font-weight: 600;
  color: white;
  background: var(--color-primary);
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.deleted-badge {
  font-size: var(--font-sm);
  font-weight: 600;
  color: white;
  background: #999;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.archived-badge {
  font-size: var(--font-sm);
  font-weight: 600;
  color: white;
  background: #FF9500;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  margin-left: 12rpx;
  flex-shrink: 0;
}

/* ============================================
   成员头像行
   ============================================ */

.avatar-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.mini-avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: -8rpx;
  border: 3rpx solid white;
  position: relative;
  z-index: 1;
}

.mini-avatar:last-of-type {
  margin-right: 0;
}

.avatar-char {
  font-size: var(--font-sm);
  font-weight: 600;
  color: white;
}

.more-count {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-left: 12rpx;
  font-weight: 500;
}

.member-add-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 2rpx dashed var(--border-color);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 8rpx;
}

.add-member-icon {
  font-size: var(--font-base);
  color: var(--text-tertiary);
  line-height: 1;
}

/* ============================================
   统计行
   ============================================ */

.card-stats {
  display: flex;
  align-items: center;
  background: var(--bg-primary);
  border-radius: var(--border-radius-md);
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
}

.stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-label {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
  margin-bottom: 4rpx;
}

.stat-value {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--text-primary);
}

.stat-value.expense {
  color: var(--color-primary);
  font-weight: 700;
}

.stat-divider {
  width: 1rpx;
  height: 40rpx;
  background: var(--border-color);
}

/* ============================================
   底部日期 + 操作按钮
   ============================================ */

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-date {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

.card-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  font-size: var(--font-sm);
  padding: 16rpx 28rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.action-btn.enter {
  background: var(--color-primary);
  color: white;
}

.action-btn.danger {
  color: var(--color-danger);
  background: #FFF0F0;
}

.action-btn.warn {
  color: #FF9500;
  background: #FFF8F0;
}

/* ============================================
   底部新建按钮
   ============================================ */

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: var(--bg-card);
  border-top: 1rpx solid var(--border-color);
  z-index: 100;
}

.bottom-add-btn {
  width: 100%;
  height: 88rpx;
  background: var(--color-primary);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-white);
  box-shadow: 0 4rpx 16rpx rgba(52, 199, 89, 0.3);
  transition: all 150ms ease;
}

.bottom-add-hover {
  opacity: 0.85;
  transform: scale(0.98);
}

