<!-- TripSplit - 首页 / 流水·待整理·结算 -->
<view class="page-container">
  <!-- ======== 顶部账本信息卡 ======== -->
  <view class="book-header" style="background: linear-gradient(135deg, {{bookColor}} 0%, {{bookColorLight}} 100%); padding-top: {{navPaddingTop}}px;">
    <view class="header-content" style="padding-top: {{navPaddingBottom}}px;">
      <view class="header-left">
        <!-- 多账本切换 -->
        <picker
          wx:if="{{bookList.length > 0}}"
          range="{{bookList}}"
          range-key="name"
          value="{{currentBookIndex}}"
          bindchange="onBookSwitch"
        >
          <view class="book-picker">
            <text class="book-emoji" wx:if="{{currentBook}}">🏔</text>
            <text class="book-name">{{currentBook.name || '拼途记账'}}</text>
            <text class="picker-arrow" wx:if="{{bookList.length > 1}}">▾</text>
          </view>
        </picker>
        <view class="book-picker" wx:else>
          <text class="book-emoji">🏔</text>
          <text class="book-name">拼途记账</text>
        </view>
        <text class="book-manage-link" bindtap="onManageBooks">账本管理</text>
      </view>
      <view class="header-right" bindtap="onMemberTap" hover-class="hover-opacity">
        <view class="member-icon-wrap">
          <text class="member-emoji">👥</text>
          <view class="badge" wx:if="{{pendingClaimCount > 0}}">!</view>
        </view>
        <text class="member-badge-count">({{memberCount}})</text>
      </view>
    </view>
    <view class="date-range" wx:if="{{currentBook}}">
      {{currentBook.start_date}} - 至今
    </view>

    <!-- Tab 栏：圆角药丸 -->
    <view class="tab-bar">
      <view class="tab-item {{activeTab === 'flow' ? 'active' : ''}}" bindtap="switchTab" data-tab="flow">
        <text class="tab-icon-emoji">☰</text>
        <text class="tab-label">流水</text>
      </view>
      <!-- 待整理 Tab：MVP 暂不上线拍照识别功能
      <view class="tab-item {{activeTab === 'inbox' ? 'active' : ''}}" bindtap="switchTab" data-tab="inbox">
        <text class="tab-icon-emoji">📮</text>
        <text class="tab-label">待整理</text>
        <view class="red-dot" wx:if="{{inboxUnread > 0}}">{{inboxUnread > 99 ? '99+' : inboxUnread}}</view>
      </view>
      -->
      <view class="tab-item {{activeTab === 'settle' ? 'active' : ''}}" bindtap="switchTab" data-tab="settle">
        <text class="tab-icon-emoji">📊</text>
        <text class="tab-label">结算</text>
      </view>
    </view>
  </view>

  <!-- ======== 流水 Tab ======== -->
  <scroll-view
    class="content-area safe-bottom"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    wx:if="{{activeTab === 'flow'}}"
  >
    <!-- 空状态：无账本 -->
    <view class="empty-state" wx:if="{{!currentBook}}">
      <text class="empty-emoji large">🏔</text>
      <text class="empty-title">开启你的旅行记账之旅</text>
      <text class="empty-desc">创建或加入一个账本开始记录</text>
      <button class="btn-primary" bindtap="onCreateBook">+ 新建账本</button>
    </view>

    <!-- 空状态：有账本但无流水 -->
    <view class="empty-state" wx:elif="{{groupedBills.length === 0}}">
      <text class="empty-emoji">📝</text>
      <text class="empty-title">还没有记录</text>
      <text class="empty-desc">点击右下角的 + 开始记一笔</text>
    </view>

    <!-- 流水列表（时间线风格） -->
    <view class="bill-timeline" wx:else>
      <block wx:for="{{groupedBills}}" wx:key="date">
        <!-- 日期分组头 -->
        <view class="date-group-header">
          <view class="date-badge">
            <view class="date-badge-dot"></view>
            <text class="date-text">{{item.dateLabel}}</text>
            <text class="location-text" wx:if="{{item.location}}">📍 {{item.location}}</text>
          </view>
          <view class="day-summary">
            <text class="day-count">{{item.items.length}}笔</text>
            <text class="day-total">{{item.totalDisplay}}</text>
          </view>
        </view>

        <!-- 时间线 + 账单项 -->
        <view class="timeline-group">
          <view class="tl-track">
            <view
              class="timeline-item"
              wx:for="{{item.items}}"
              wx:for-item="bill"
              wx:key="id"
              bindtap="onBillTap"
              data-id="{{bill.id}}"
              hover-class="hover-card"
            >
              <!-- 左侧时间线 -->
              <view class="tl-rail">
                <view class="tl-dot"></view>
                <view class="tl-line"></view>
              </view>
              <!-- 时间 -->
              <text class="tl-time">{{bill.timeDisplay}}</text>
              <!-- 内容 -->
              <view class="tl-content">
                <view class="tl-row">
                  <view class="tl-cat">
                    <text class="tl-cat-icon">{{bill.category_icon}}</text>
                    <text class="tl-cat-name">{{bill.category_name}}</text>
                  </view>
                  <text class="tl-amount">-{{bill.amountDisplay}}</text>
                </view>
                <text class="tl-note" wx:if="{{bill.note}}">{{bill.note}}</text>
                <view class="tl-meta">
                  <text class="tl-payer">{{bill.payer_name_display}} 支付</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </block>
    </view>
  </scroll-view>

  <!-- ======== 待整理 Tab（MVP 暂不上线） ========
  <scroll-view
    class="content-area safe-bottom"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    wx:if="{{activeTab === 'inbox'}}"
  >
    <view class="empty-state" wx:if="{{inboxItems.length === 0}}">
      <view class="empty-check-circle">
        <text class="empty-check-mark">✓</text>
      </view>
      <text class="empty-title">待整理列表为空</text>
      <text class="empty-desc">拍照后的识别结果会出现在这里</text>
    </view>

    <view class="inbox-list" wx:else>
      <view class="inbox-card" wx:for="{{inboxItems}}" wx:key="id">
        <view class="inbox-thumb-placeholder">
          <text class="inbox-thumb-emoji">📷</text>
        </view>

        <view class="inbox-info" wx:if="{{item.status === 'processing'}}">
          <text class="inbox-status processing">识别中...</text>
        </view>

        <view class="inbox-info" wx:elif="{{item.ai_result}}">
          <text class="inbox-amount {{item.ai_result.confidence < 0.6 ? 'low-confidence' : ''}}">
            {{item.ai_result.confidence >= 0.6 ? item.ai_result.amountDisplay : '?'}}
          </text>
          <text class="inbox-category">{{item.ai_result.category_name}}</text>

          <view class="inbox-actions" wx:if="{{item.status === 'pending'}}">
            <view class="action-btn confirm" bindtap="onConfirmInbox" data-id="{{item.id}}">✓ 确认</view>
            <view class="action-btn reject" bindtap="onRejectInbox" data-id="{{item.id}}">✕ 删除</view>
          </view>
        </view>

        <view class="inbox-info" wx:elif="{{item.status === 'error'}}">
          <text class="inbox-status error">识别失败，请重试</text>
          <view class="inbox-actions">
            <view class="action-btn retry" bindtap="onRetryInbox" data-id="{{item.id}}">重试</view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
  -->

  <!-- ======== 结算 Tab ======== -->
  <scroll-view
    class="content-area safe-bottom"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    wx:if="{{activeTab === 'settle'}}"
  >
    <view class="settle-container">
      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{!settlementResult || settlementResult.transfers.length === 0}}">
        <text class="empty-emoji">📊</text>
        <text class="empty-title">暂无数据可结算</text>
        <text class="empty-desc">记录更多开销后即可查看结算方案</text>
      </view>

      <!-- 结算结果 -->
      <view class="settle-result" wx:else>
        <text class="settle-title">结算方案</text>
        <text class="settle-subtitle">已优化为最少转账次数（{{settlementResult.totalTransfers}}笔）</text>

        <view class="transfer-card {{item.status !== 'pending' ? 'card-done' : ''}}" wx:for="{{settlementResult.transfers}}" wx:key="id">
          <view class="transfer-row">
            <view class="transfer-person from">
              <text class="person-label">付款人</text>
              <text class="person-name">{{item.from_name}}</text>
            </view>

            <view class="transfer-arrow">
              <text class="arrow-text">→</text>
            </view>

            <view class="transfer-person to">
              <text class="person-label">收款人</text>
              <text class="person-name">{{item.to_name}}</text>
            </view>
          </view>

          <!-- 金额行：总金额 + 待结算金额 -->
          <view class="amount-row">
            <view class="amount-info">
              <text class="amount-total-label">结算金额</text>
              <text class="amount-total-value">{{item.amountDisplay}}</text>
              <text class="amount-settled-hint" wx:if="{{item.settledAmount > 0 && item.pendingAmount > 0}}">已结 {{item.settledAmountDisplay}}</text>
            </view>
            <view class="amount-pending" wx:if="{{item.status === 'pending'}}">
              <text class="pending-label">待结算</text>
              <text class="pending-value">{{item.pendingAmountDisplay}}</text>
            </view>
            <view class="amount-settled" wx:elif="{{item.status === 'paid'}}">
              <text class="settled-label">已结算</text>
              <text class="settled-value">{{item.amountDisplay}}</text>
            </view>
            <view class="amount-settled" wx:elif="{{item.status === 'forgiven'}}">
              <text class="forgiven-label">已免除</text>
              <text class="forgiven-value">{{item.amountDisplay}}</text>
            </view>
          </view>

          <!-- pending：操作按钮 -->
          <view class="transfer-actions" wx:if="{{item.status === 'pending'}}">
            <view class="btn-mark-paid" bindtap="onMarkPaid" data-id="{{item.id}}" hover-class="hover-opacity">标记已付</view>
            <view class="btn-forgive" bindtap="onForgive" data-id="{{item.id}}" hover-class="hover-opacity">下顿他请</view>
          </view>

          <!-- paid -->
          <view class="transfer-status" wx:if="{{item.status === 'paid'}}">
            <text class="status-tag status-paid">✓ 已付款</text>
            <view class="undo-btn" bindtap="onUndoSettle" data-id="{{item.id}}" hover-class="hover-opacity">撤销</view>
          </view>

          <!-- forgiven -->
          <view class="transfer-status" wx:if="{{item.status === 'forgiven'}}">
            <text class="status-tag status-forgiven">已被免除</text>
            <view class="undo-btn" bindtap="onUndoSettle" data-id="{{item.id}}" hover-class="hover-opacity">撤销</view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- ======== 组件挂载 ======== -->

  <!-- FAB 浮动菜单 -->
  <fab-menu
    bind:select="onFabSelect"
  />

  <!-- 成员管理弹窗 -->
  <member-popup
    visible="{{memberPopupVisible}}"
    bookId="{{currentBook && currentBook.id}}"
    bookName="{{currentBook && currentBook.name}}"
    members="{{members}}"
    bind:onclose="closeMemberPopup"
    bind:onaddshadow="onAddShadowMember"
  />

  <!-- 手动记账面板 -->
  <add-bill-panel
    visible="{{addPanelVisible}}"
    members="{{members}}"
    bind:onclose="closeAddPanel"
    bind:onsubmit="onAddBillSubmit"
  />

  <!-- 账单详情弹窗 -->
  <bill-detail-popup
    visible="{{detailVisible}}"
    bill="{{selectedBill}}"
    currencySymbol="{{currencySymbol}}"
    bind:onclose="closeDetailPopup"
    bind:ondelete="onDeleteBill"
  />
</view>
