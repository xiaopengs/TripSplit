<!-- 拼途记账 - 首页 / 流水列表 -->
<view class="page-container">
  <!-- 顶部账本信息卡 -->
  <view class="book-header" style="background: linear-gradient(135deg, {{bookColor}} 0%, {{bookColorLight}} 100%);">
    <view class="header-content">
      <view class="header-left">
        <image class="book-icon" src="/images/icons/book.png" mode="aspectFit" wx:if="{{currentBook}}" />
        <text class="book-name">{{currentBook.name || '拼途记账'}}</text>
        <text class="member-count">· {{memberCount}}人</text>
      </view>
      <view class="header-right" bindtap="onMemberTap" hover-class="hover-opacity">
        <image class="member-icon" src="/images/icons/members.png" mode="aspectFit" />
        <view class="badge" wx:if="{{pendingClaimCount > 0}}">{{pendingClaimCount}}</view>
      </view>
    </view>
    <view class="date-range" wx:if="{{currentBook}}">
      {{currentBook.start_date}} - 至今
    </view>

    <!-- Tab 栏 -->
    <view class="tab-bar">
      <view class="tab-item {{activeTab === 'flow' ? 'active' : ''}}" bindtap="switchTab" data-tab="flow">
        <image class="tab-icon" src="/images/icons/flow_{{activeTab === 'flow' ? 'active' : 'normal'}}.png" mode="aspectFit" />
        <text>流水</text>
      </view>
      <view class="tab-item {{activeTab === 'inbox' ? 'active' : ''}}" bindtap="switchTab" data-tab="inbox">
        <image class="tab-icon" src="/images/icons/inbox_{{activeTab === 'inbox' ? 'active' : 'normal'}}.png" mode="aspectFit" />
        <text>待整理</text>
        <view class="red-dot" wx:if="{{inboxUnread > 0}}">{{inboxUnread > 99 ? '99+' : inboxUnread}}</view>
      </view>
      <view class="tab-item {{activeTab === 'settle' ? 'active' : ''}}" bindtap="switchTab" data-tab="settle">
        <image class="tab-icon" src="/images/icons/settle_{{activeTab === 'settle' ? 'active' : 'normal'}}.png" mode="aspectFit" />
        <text>结算</text>
      </view>
    </view>
  </view>

  <!-- 流水 Tab 内容 -->
  <scroll-view 
    class="content-area safe-bottom" 
    scroll-y 
    enhanced 
    show-scrollbar="{{false}}"
    wx:if="{{activeTab === 'flow'}}"
  >
    <!-- 空状态：无账本 -->
    <view class="empty-state" wx:if="{{!currentBook}}">
      <image class="empty-logo" src="/images/logo.png" mode="aspectFit" />
      <text class="empty-title">开启你的旅行记账之旅</text>
      <text class="empty-desc">创建或加入一个账本开始记录</text>
      <button class="btn-primary" bindtap="onCreateBook">+ 新建账本</button>
    </view>

    <!-- 空状态：有账本但无流水 -->
    <view class="empty-state" wx:elif="{{groupedBills.length === 0}}">
      <image class="empty-icon" src="/images/icons/empty_bill.png" mode="aspectFit" />
      <text class="empty-title">还没有记录</text>
      <text class="empty-desc">点击右下角的 + 开始记一笔</text>
    </view>

    <!-- 流水列表 -->
    <view class="bill-list" wx:else>
      <block wx:for="{{groupedBills}}" wx:key="date">
        <!-- 日期分组头 -->
        <view class="date-group-header">
          <view class="date-info">
            <view class="date-dot"></view>
            <text class="date-text">{{item.dateLabel}}</text>
            <text class="location-text" wx:if="{{item.location}}">📍 {{item.location}}</text>
            <text class="count-text">· {{item.items.length}}笔</text>
          </view>
          <text class="day-total">{{item.totalDisplay}}</text>
          <text class="day-label">支出</text>
        </view>

        <!-- 账单卡片 -->
        <view 
          class="bill-card" 
          wx:for="{{item.items}}" 
          wx:for-item="bill"
          wx:key="id"
          bindtap="onBillTap"
          data-id="{{bill.id}}"
          hover-class="hover-card"
        >
          <view class="card-left">
            <view class="category-icon-wrap">
              <text class="category-icon">{{bill.category_icon}}</text>
            </view>
          </view>
          <view class="card-middle">
            <text class="bill-title">{{bill.note || bill.category_name}}</text>
            <view class="bill-meta">
              <text class="payer">{{bill.payer_name}} 支付</text>
              <text class="time-separator">·</text>
              <text class="time">{{bill.timeDisplay}}</text>
            </view>
            <view class="split-preview" wx:if="{{bill.splits && bill.splits.length > 0}}">
              <text class="split-label">分摊:</text>
              <text class="split-names" wx:for="{{bill.splits}}" wx:for-item="s" wx:key="member_id">{{s.name}}</text>
            </view>
          </view>
          <view class="card-right">
            <text class="bill-amount">{{bill.amountDisplay}}</text>
          </view>
        </view>
      </block>
    </view>
  </scroll-view>

  <!-- 待整理 Tab 内容 -->
  <scroll-view 
    class="content-area safe-bottom" 
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    wx:if="{{activeTab === 'inbox'}}"
  >
    <view class="empty-state" wx:if="{{inboxItems.length === 0}}">
      <image class="empty-icon" src="/images/icons/check_circle.png" mode="aspectFit" />
      <text class="empty-title">待整理列表为空</text>
      <text class="empty-desc">拍照后的识别结果会出现在这里</text>
    </view>

    <view class="inbox-list" wx:else>
      <view class="inbox-card" wx:for="{{inboxItems}}" wx:key="id">
        <image class="inbox-thumb" src="{{item.image_url || item.image_local}}" mode="aspectFill" />
        
        <view class="inbox-info" wx:if="{{item.status === 'processing'}}">
          <text class="inbox-status processing">识别中...</text>
        </view>

        <view class="inbox-info" wx:elif="{{item.ai_result}}">
          <text class="inbox-amount {{item.ai_result.confidence < 0.6 ? 'low-confidence' : ''}}">
            {{item.ai_result.confidence >= 0.6 ? item.ai_result.amountDisplay : '?'}}
          </text>
          <text class="inbox-category">{{item.ai_result.category_name}}</text>
          
          <!-- 操作按钮 -->
          <view class="inbox-actions" wx:if="{{item.status === 'pending'}}">
            <view class="action-btn confirm" bindtap="onConfirmInbox" data-id="{{item.id}}">✓ 确认</view>
            <view class="action-btn reject" bindtap="onRejectInbox" data-id="{{item.id}}">✕ 删除</view>
          </view>
        </view>

        <view class="inbox-info" wx:elif="{{item.status === 'error'}}">
          <text class="inbox-status error">识别失败，请重试</text>
          <view class="inbox-actions">
            <view class="action-btn retry" bindtap="onRetryInbox" data-id="{{item.id}}">重试</view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 结算 Tab 内容 -->
  <scroll-view 
    class="content-area safe-bottom"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    wx:if="{{activeTab === 'settle'}}"
  >
    <view class="settle-container">
      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{!settlementResult || settlementResult.transfers.length === 0}}">
        <image class="empty-icon" src="/images/icons/calc.png" mode="aspectFit" />
        <text class="empty-title">暂无数据可结算</text>
        <text class="empty-desc">记录更多开销后即可查看结算方案</text>
      </view>

      <!-- 结算结果 -->
      <view class="settle-result" wx:else>
        <text class="settle-title">结算方案</text>
        <text class="settle-subtitle">已优化为最少转账次数（{{settlementResult.totalTransfers}}笔）</text>

        <view class="transfer-card" wx:for="{{settlementResult.transfers}}" wx:key="id">
          <view class="transfer-row">
            <view class="transfer-person from">
              <text class="person-label">付款人</text>
              <text class="person-name">{{item.from_name}}</text>
            </view>
            
            <view class="transfer-arrow">
              <text>→</text>
            </view>
            
            <view class="transfer-person to">
              <text class="person-label">收款人</text>
              <text class="person-name">{{item.to_name}}</text>
            </view>
          </view>

          <text class="transfer-amount">{{item.amountDisplay}}</text>

          <view class="transfer-actions">
            <button class="btn-mark-paid" wx:if="{{item.status !== 'paid'}}" bindtap="onMarkPaid" data-id="{{item.id}}">标记已付</button>
            <text class="paid-tag" wx:else>✓ 已付款</text>
            
            <button class="btn-forgive" wx:if="{{item.status !== 'forgiven' && item.status !== 'paid'}}" bindtap="onForgive" data-id="{{item.id}}">下顿他请</button>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- FAB 扇形菜单 -->
  <fab-menu 
    visible="{{fabVisible}}"
    bind:onselect="onFabSelect"
  />

  <!-- 成员管理弹窗 -->
  <member-popup 
    visible="{{memberPopupVisible}}"
    members="{{members}}"
    bind:onclose="closeMemberPopup"
    bind:onaddshadow="onAddShadowMember"
    bind:onclaim="onClaimMember"
  />

  <!-- 手动记账面板 -->
  <add-bill-panel 
    visible="{{addPanelVisible}}"
    members="{{members}}"
    bind:onclose="closeAddPanel"
    bind:onsubmit="onAddBillSubmit"
  />

  <!-- 账单详情弹窗 -->
  <bill-detail-popup 
    visible="{{detailVisible}}"
    bill="{{selectedBill}}"
    currencySymbol="{{currencySymbol}}"
    bind:onclose="closeDetailPopup"
  />
</view>
