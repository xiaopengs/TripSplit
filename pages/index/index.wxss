/* ============================================
   TripSplit - 首页样式
   流水 · 待整理 · 结算
   ============================================ */

/* === 页面容器 (flex 布局，撑满视口) === */
.page-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: var(--bg-primary);
}

/* ============================================
   顶部账本信息卡 (绿色渐变)
   ============================================ */
.book-header {
  flex-shrink: 0;
  padding-bottom: 24rpx;
}

.header-content {
  padding: 24rpx 32rpx 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* -- 左侧：账本图标 + 名称 + 人数 -- */
.header-left {
  display: flex;
  align-items: center;
}

.book-emoji {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.book-name {
  color: var(--text-white);
  font-size: 36rpx;
  font-weight: 700;
}

.member-count {
  color: rgba(255, 255, 255, 0.7);
  font-size: 28rpx;
  margin-left: 8rpx;
}

/* -- 右侧：成员图标 + 橙色徽章 -- */
.header-right {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.member-emoji {
  font-size: 40rpx;
  opacity: 0.95;
}

.badge {
  position: absolute;
  top: -2rpx;
  right: -2rpx;
  background: #FF9500;
  color: white;
  font-size: 20rpx;
  font-weight: 700;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
}

/* -- 日期范围 -- */
.date-range {
  color: rgba(255, 255, 255, 0.75);
  font-size: 24rpx;
  padding: 0 32rpx 20rpx;
}

/* ============================================
   Tab 栏 (圆角药丸式)
   ============================================ */
.tab-bar {
  display: flex;
  background: rgba(255, 255, 255, 0.2);
  margin: 0 32rpx;
  border-radius: 44rpx;
  padding: 6rpx;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  color: rgba(255, 255, 255, 0.7);
  font-size: 26rpx;
  border-radius: 40rpx;
  position: relative;
  transition: all 250ms var(--spring-curve);
}

.tab-item.active {
  background: #FFFFFF;
  color: var(--color-primary);
  font-weight: 700;
}

.tab-icon-emoji {
  font-size: 26rpx;
  margin-right: 8rpx;
}

.tab-label {
  font-size: 26rpx;
}

/* 激活态让子文本也继承颜色和粗细 */
.tab-item.active .tab-icon-emoji,
.tab-item.active .tab-label {
  color: var(--color-primary);
  font-weight: 700;
}

.red-dot {
  position: absolute;
  top: 2rpx;
  right: calc(50% - 54rpx);
  background: #FF3B30;
  color: white;
  font-size: 18rpx;
  min-width: 28rpx;
  height: 28rpx;
  line-height: 28rpx;
  text-align: center;
  border-radius: 14rpx;
  padding: 0 6rpx;
}

/* ============================================
   内容区域 (flex 撑满剩余空间)
   ============================================ */
.content-area {
  flex: 1;
  height: 0;
}

/* ============================================
   空状态
   ============================================ */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 48rpx 120rpx;
}

.empty-emoji {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.55;
}

.empty-emoji.large {
  font-size: 160rpx;
}

/* 待整理空态：灰色圆形勾选 */
.empty-check-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #E5E5EA;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.empty-check-mark {
  font-size: 72rpx;
  color: #AEAEB2;
  font-weight: 700;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 40rpx;
  text-align: center;
  line-height: 1.6;
}

.btn-primary {
  background: var(--color-primary) !important;
  color: white !important;
  font-size: 30rpx;
  font-weight: 600;
  padding: 20rpx 60rpx;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(52, 199, 89, 0.35);
}

/* ============================================
   流水列表
   ============================================ */
.bill-list {
  padding: 0 24rpx;
}

/* -- 日期分组头 -- */
.date-group-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 8rpx 16rpx;
}

.date-info {
  display: flex;
  align-items: center;
  overflow: hidden;
}

.date-dot {
  width: 6rpx;
  height: 40rpx;
  background: var(--color-primary);
  border-radius: 3rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.date-text {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  flex-shrink: 0;
}

.location-text {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-left: 12rpx;
  flex-shrink: 0;
}

.count-text {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-left: 8rpx;
  flex-shrink: 0;
}

.day-summary {
  display: flex;
  align-items: baseline;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.day-total {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.day-label {
  font-size: 20rpx;
  color: var(--text-secondary);
  margin-left: 2rpx;
}

/* ============================================
   账单卡片
   ============================================ */
.bill-card {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border-radius: var(--border-radius-lg);
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
  transition: transform 150ms ease, opacity 150ms ease;
}

.hover-card {
  transform: scale(0.985);
  opacity: 0.7;
}

/* -- 左侧：分类 emoji -- */
.card-left {
  margin-right: 20rpx;
  flex-shrink: 0;
}

.category-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: #F2F2F7;
  display: flex;
  align-items: center;
  justify-content: center;
}

.category-icon {
  font-size: 44rpx;
}

/* -- 中间：标题 / 支付人·时间 / 分摊 -- */
.card-middle {
  flex: 1;
  overflow: hidden;
}

.bill-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bill-meta {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
}

.payer,
.time {
  font-size: 24rpx;
}

.time-separator {
  margin: 0 8rpx;
}

.split-preview {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-top: 6rpx;
}

.split-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-right: 6rpx;
}

.split-names {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-right: 8rpx;
}

/* -- 右侧：金额 -- */
.card-right {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.bill-amount {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-primary);
  white-space: nowrap;
}

/* ============================================
   待整理列表
   ============================================ */
.inbox-list {
  padding: 24rpx;
}

.inbox-card {
  display: flex;
  align-items: center;
  background: white;
  border-radius: var(--border-radius-lg);
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
}

/* 图片占位符（替代 <image>） */
.inbox-thumb-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--border-radius-sm);
  margin-right: 20rpx;
  flex-shrink: 0;
  background: #F2F2F7;
  display: flex;
  align-items: center;
  justify-content: center;
}

.inbox-thumb-emoji {
  font-size: 48rpx;
  opacity: 0.5;
}

.inbox-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.inbox-status {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.inbox-status.processing {
  color: var(--color-info);
}

.inbox-status.error {
  color: var(--color-danger);
}

.inbox-amount {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.inbox-amount.low-confidence {
  color: var(--color-danger);
}

.inbox-category {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.inbox-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}

.action-btn {
  padding: 10rpx 28rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  text-align: center;
}

.action-btn.confirm {
  background: var(--color-primary);
  color: white;
}

.action-btn.reject {
  background: #FFF0F0;
  color: var(--color-danger);
}

.action-btn.retry {
  background: #F0F5FF;
  color: var(--color-info);
}

/* ============================================
   结算页面
   ============================================ */
.settle-container {
  padding: 32rpx 24rpx;
}

.settle-title {
  display: block;
  text-align: center;
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.settle-subtitle {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 40rpx;
}

/* -- 转账卡片 -- */
.transfer-card {
  background: white;
  border-radius: var(--border-radius-xl);
  padding: 36rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-md);
}

.transfer-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.transfer-person {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.person-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.person-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

/* 绿色圆形箭头 */
.transfer-arrow {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin: 0 20rpx;
}

.arrow-text {
  color: white;
  font-size: 36rpx;
  font-weight: 700;
}

/* 大号绿色金额 */
.transfer-amount {
  display: block;
  text-align: center;
  font-size: 52rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin: 24rpx 0;
}

/* -- 操作按钮行 -- */
.transfer-actions {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin-top: 16rpx;
}

.btn-mark-paid,
.btn-forgive {
  flex: 1;
  padding: 18rpx 0;
  border-radius: 40rpx;
  font-size: 26rpx;
  text-align: center;
  line-height: 1.4;
}

.btn-mark-paid {
  background: #F2F2F7;
  color: var(--text-primary);
}

.btn-forgive {
  border: 2rpx solid var(--color-primary);
  color: var(--color-primary);
  background: transparent;
}

.paid-tag {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 26rpx;
  color: var(--color-success);
  font-weight: 500;
}

/* ============================================
   通用交互效果
   ============================================ */
.hover-opacity {
  opacity: 0.7;
}
