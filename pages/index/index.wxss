/* ============================================
   TripSplit - 首页样式
   流水 · 待整理 · 结算
   ============================================ */

.page-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: var(--bg-primary);
}

/* ============================================
   顶部账本信息卡 (绿色渐变)
   ============================================ */
.book-header {
  flex-shrink: 0;
  padding-bottom: 24rpx;
}

.header-content {
  padding: 24rpx 32rpx 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-left {
  display: flex;
  align-items: center;
}

/* 多账本选择器 */
.book-picker {
  display: flex;
  align-items: center;
}

/* CSS 图标：账本 */
.icon-book {
  width: 36rpx;
  height: 36rpx;
  border: 3rpx solid rgba(255,255,255,0.9);
  border-radius: 4rpx 10rpx 4rpx 4rpx;
  margin-right: 12rpx;
  position: relative;
  flex-shrink: 0;
}
.icon-book::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  height: 2rpx;
  background: rgba(255,255,255,0.9);
}

.book-name {
  color: var(--text-white);
  font-size: var(--font-lg);
  font-weight: 700;
}

.picker-arrow {
  color: rgba(255, 255, 255, 0.7);
  font-size: var(--font-sm);
  margin-left: 6rpx;
}

.book-manage-link {
  color: rgba(255, 255, 255, 0.75);
  font-size: var(--font-sm);
  margin-left: 16rpx;
  padding: 6rpx 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.35);
  border-radius: 20rpx;
}

/* 右侧成员图标 */
.header-right {
  display: flex;
  align-items: center;
}

.member-icon-wrap {
  position: relative;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* CSS 图标：成员（两人 — 头 + 肩膀） */
.icon-members {
  width: 36rpx;
  height: 32rpx;
  position: relative;
  flex-shrink: 0;
}
/* 两人合用的肩膀弧线 */
.icon-members::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 2rpx;
  width: 32rpx;
  height: 14rpx;
  border-radius: 14rpx 14rpx 4rpx 4rpx;
  background: rgba(255, 255, 255, 0.4);
}
/* 两个头部圆点（第二个用 box-shadow） */
.icon-members::after {
  content: '';
  position: absolute;
  top: 0;
  left: 4rpx;
  width: 13rpx;
  height: 13rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.85);
  box-shadow: 15rpx 5rpx 0 rgba(255, 255, 255, 0.95);
}

.member-badge-count {
  color: rgba(255, 255, 255, 0.8);
  font-size: var(--font-sm);
  margin-left: 4rpx;
  font-weight: 500;
}

.badge {
  position: absolute;
  top: -2rpx;
  right: -2rpx;
  background: #FF9500;
  color: white;
  font-size: var(--font-xs);
  font-weight: 700;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
}

.date-range {
  color: rgba(255, 255, 255, 0.75);
  font-size: var(--font-sm);
  padding: 0 32rpx 20rpx;
}

/* ============================================
   Tab 栏 (圆角药丸式)
   ============================================ */
.tab-bar {
  display: flex;
  background: rgba(255, 255, 255, 0.2);
  margin: 0 32rpx;
  border-radius: 44rpx;
  padding: 6rpx;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  color: rgba(255, 255, 255, 0.7);
  font-size: var(--font-base);
  border-radius: 40rpx;
  position: relative;
  transition: all 250ms var(--spring-curve);
}

.tab-item.active {
  background: #FFFFFF;
  color: var(--color-primary);
  font-weight: 700;
}

/* CSS 图标：流水 Tab（三横线列表） */
.icon-tab-flow {
  width: 16px;
  height: 12px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  margin-right: 6rpx;
  flex-shrink: 0;
}
.icon-tab-flow::before,
.icon-tab-flow::after {
  content: '';
  height: 2px;
  border-radius: 1px;
  background: currentColor;
}
.icon-tab-flow view {
  display: none;
}
.icon-tab-flow {
  border-top: 2px solid currentColor;
  border-bottom: 2px solid currentColor;
  border-radius: 1px;
  background: linear-gradient(currentColor 50%, currentColor 50%) center/100% 2px no-repeat;
}

/* CSS 图标：结算 Tab（交换箭头） */
.icon-tab-settle {
  width: 16px;
  height: 14px;
  position: relative;
  margin-right: 6rpx;
  flex-shrink: 0;
}
.icon-tab-settle::before {
  content: '';
  position: absolute;
  top: 1px;
  left: 2px;
  width: 10px;
  height: 2px;
  background: currentColor;
  border-radius: 1px;
  transform: rotate(-30deg);
}
.icon-tab-settle::after {
  content: '';
  position: absolute;
  bottom: 1px;
  right: 2px;
  width: 10px;
  height: 2px;
  background: currentColor;
  border-radius: 1px;
  transform: rotate(-30deg);
}

.tab-label {
  font-size: var(--font-base);
}

.tab-item.active .tab-label {
  color: var(--color-primary);
  font-weight: 700;
}

.red-dot {
  position: absolute;
  top: 2rpx;
  right: calc(50% - 54rpx);
  background: #FF3B30;
  color: white;
  font-size: 18rpx;
  min-width: 28rpx;
  height: 28rpx;
  line-height: 28rpx;
  text-align: center;
  border-radius: 14rpx;
  padding: 0 6rpx;
}

/* ============================================
   内容区域
   ============================================ */
.content-area {
  flex: 1;
  height: 0;
}

/* ============================================
   只读提示条
   ============================================ */
.readonly-banner {
  margin: 16rpx 24rpx;
  padding: 20rpx 24rpx;
  background: #FFF8E1;
  border-radius: var(--border-radius-lg);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.readonly-text {
  font-size: var(--font-sm);
  color: #8B6914;
  flex: 1;
}

.readonly-actions {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.readonly-btn {
  font-size: var(--font-sm);
  color: #FF3B30;
  font-weight: 600;
  padding: 8rpx 16rpx;
}

/* ============================================
   时间线流水列表
   ============================================ */
.bill-timeline {
  padding: 0 24rpx 24rpx;
}

/* -- 日期分组头 -- */
.date-group-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx 20rpx;
  background: var(--bg-card);
  border-radius: var(--border-radius-lg);
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
}

.date-badge {
  display: flex;
  align-items: center;
  overflow: hidden;
}

.date-badge-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--color-primary);
  margin-right: 16rpx;
  flex-shrink: 0;
  box-shadow: 0 0 0 4rpx rgba(52, 199, 89, 0.15);
}

.date-text {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--text-primary);
  flex-shrink: 0;
}

.day-summary {
  display: flex;
  align-items: baseline;
  flex-shrink: 0;
  margin-left: 16rpx;
  gap: 8rpx;
}

.day-count {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

.day-total {
  font-size: var(--font-base);
  font-weight: 700;
  color: var(--color-primary);
}

/* -- 时间线组 -- */
.timeline-group {
  margin-left: 8rpx;
  margin-bottom: 16rpx;
}

.tl-track {
  margin-left: 8rpx;
  border-left: 4rpx solid rgba(52, 199, 89, 0.15);
  padding-left: 0;
}

.timeline-item {
  display: flex;
  align-items: flex-start;
  padding: 0 0 0 12rpx;
  position: relative;
  margin-bottom: 12rpx;
  transition: opacity 150ms ease;
}

.timeline-item:active {
  opacity: 0.7;
}


/* 左侧轨道（圆点） */
.tl-rail {
  width: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  position: relative;
  margin-left: -18rpx;
  padding-top: 20rpx;
}

.tl-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--color-primary);
  flex-shrink: 0;
  position: relative;
  z-index: 1;
  border: 3rpx solid #FFFFFF;
  box-shadow: 0 0 0 2rpx rgba(52, 199, 89, 0.2);
}

.tl-line {
  display: none;
}

/* 时间 */
.tl-time {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  width: 72rpx;
  flex-shrink: 0;
  padding-top: 20rpx;
  text-align: center;
  margin-right: 12rpx;
}

/* 内容区 */
.tl-content {
  flex: 1;
  background: var(--bg-card);
  border-radius: var(--border-radius-md);
  padding: 24rpx;
  min-width: 0;
  box-shadow: var(--shadow-sm);
}

.tl-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.tl-cat {
  display: flex;
  align-items: center;
}

.tl-cat-icon {
  font-size: var(--font-md);
  margin-right: 8rpx;
}

.tl-cat-name {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--text-primary);
}

.tl-amount {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--color-primary);
  flex-shrink: 0;
  margin-left: 16rpx;
}

.tl-note {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  display: block;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tl-meta {
  margin-top: 8rpx;
}

.tl-payer {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

.tl-location {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  margin-left: 12rpx;
}

.tl-location::before {
  content: '·';
  margin-right: 12rpx;
}

/* ============================================
   待整理列表
   ============================================ */
.inbox-list {
  padding: 24rpx;
}

.inbox-card {
  display: flex;
  align-items: center;
  background: white;
  border-radius: var(--border-radius-lg);
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
}

.inbox-thumb-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--border-radius-sm);
  margin-right: 20rpx;
  flex-shrink: 0;
  background: #F2F2F7;
  display: flex;
  align-items: center;
  justify-content: center;
}

.inbox-thumb-emoji {
  font-size: var(--font-xl);
  opacity: 0.5;
}

.inbox-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.inbox-status {
  font-size: var(--font-base);
  color: var(--text-secondary);
}

.inbox-status.processing {
  color: var(--color-info);
}

.inbox-status.error {
  color: var(--color-danger);
}

.inbox-amount {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-primary);
}

.inbox-amount.low-confidence {
  color: var(--color-danger);
}

.inbox-category {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.inbox-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}

.action-btn {
  padding: 10rpx 28rpx;
  border-radius: 32rpx;
  font-size: var(--font-sm);
  text-align: center;
}

.action-btn.confirm {
  background: var(--color-primary);
  color: white;
}

.action-btn.reject {
  background: #FFF0F0;
  color: var(--color-danger);
}

.action-btn.retry {
  background: #F0F5FF;
  color: var(--color-info);
}

/* ============================================
   结算页面 (首页内嵌 — 共享样式在 app.wxss)
   ============================================ */
.settle-container {
  padding: 32rpx 24rpx;
}

.settle-title {
  display: block;
  text-align: center;
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.settle-subtitle {
  display: block;
  text-align: center;
  font-size: var(--font-base);
  color: var(--text-secondary);
  margin-bottom: 40rpx;
}

.transfer-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.transfer-person {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.person-label {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.person-name {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
}

.transfer-arrow {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin: 0 20rpx;
}

/* 右箭头白色变体 */
.transfer-arrow .icon-arrow-right {
  border-color: white;
}

.btn-mark-paid {
  flex: 1;
  padding: 18rpx 0;
  border-radius: 40rpx;
  font-size: var(--font-base);
  text-align: center;
  line-height: 1.4;
  background: #F2F2F7;
  color: var(--text-primary);
}

