/* ============================================
   TripSplit - 首页样式
   流水 · 待整理 · 结算
   ============================================ */

.page-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: var(--bg-primary);
}

/* ============================================
   顶部账本信息卡 (绿色渐变)
   ============================================ */
.book-header {
  flex-shrink: 0;
  padding-bottom: 24rpx;
}

.header-content {
  padding: 24rpx 32rpx 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-left {
  display: flex;
  align-items: center;
}

/* 多账本选择器 */
.book-picker {
  display: flex;
  align-items: center;
}

.book-emoji {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.book-name {
  color: var(--text-white);
  font-size: var(--font-lg);
  font-weight: 700;
}

.picker-arrow {
  color: rgba(255, 255, 255, 0.7);
  font-size: var(--font-sm);
  margin-left: 6rpx;
}

.member-count {
  color: rgba(255, 255, 255, 0.7);
  font-size: var(--font-base);
  margin-left: 8rpx;
}

.book-manage-link {
  color: rgba(255, 255, 255, 0.75);
  font-size: var(--font-sm);
  margin-left: 16rpx;
  padding: 6rpx 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.35);
  border-radius: 20rpx;
}

/* 右侧成员图标 */
.header-right {
  display: flex;
  align-items: center;
}

.member-icon-wrap {
  position: relative;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.member-emoji {
  font-size: 40rpx;
  opacity: 0.95;
}

.member-badge-count {
  color: rgba(255, 255, 255, 0.8);
  font-size: var(--font-sm);
  margin-left: 4rpx;
  font-weight: 500;
}

.badge {
  position: absolute;
  top: -2rpx;
  right: -2rpx;
  background: #FF9500;
  color: white;
  font-size: var(--font-xs);
  font-weight: 700;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
}

.date-range {
  color: rgba(255, 255, 255, 0.75);
  font-size: var(--font-sm);
  padding: 0 32rpx 20rpx;
}

/* ============================================
   Tab 栏 (圆角药丸式)
   ============================================ */
.tab-bar {
  display: flex;
  background: rgba(255, 255, 255, 0.2);
  margin: 0 32rpx;
  border-radius: 44rpx;
  padding: 6rpx;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  color: rgba(255, 255, 255, 0.7);
  font-size: var(--font-base);
  border-radius: 40rpx;
  position: relative;
  transition: all 250ms var(--spring-curve);
}

.tab-item.active {
  background: #FFFFFF;
  color: var(--color-primary);
  font-weight: 700;
}

.tab-icon-emoji {
  font-size: var(--font-base);
  margin-right: 8rpx;
}

.tab-label {
  font-size: var(--font-base);
}

.tab-item.active .tab-icon-emoji,
.tab-item.active .tab-label {
  color: var(--color-primary);
  font-weight: 700;
}

.red-dot {
  position: absolute;
  top: 2rpx;
  right: calc(50% - 54rpx);
  background: #FF3B30;
  color: white;
  font-size: 18rpx;
  min-width: 28rpx;
  height: 28rpx;
  line-height: 28rpx;
  text-align: center;
  border-radius: 14rpx;
  padding: 0 6rpx;
}

/* ============================================
   内容区域
   ============================================ */
.content-area {
  flex: 1;
  height: 0;
}

/* ============================================
   时间线流水列表
   ============================================ */
.bill-timeline {
  padding: 0 24rpx 24rpx;
}

/* -- 日期分组头 -- */
.date-group-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx 20rpx;
  background: var(--bg-card);
  border-radius: var(--border-radius-lg);
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
}

.date-badge {
  display: flex;
  align-items: center;
  overflow: hidden;
}

.date-badge-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--color-primary);
  margin-right: 16rpx;
  flex-shrink: 0;
  box-shadow: 0 0 0 4rpx rgba(52, 199, 89, 0.15);
}

.date-text {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--text-primary);
  flex-shrink: 0;
}

.location-text {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-left: 12rpx;
  flex-shrink: 0;
}

.day-summary {
  display: flex;
  align-items: baseline;
  flex-shrink: 0;
  margin-left: 16rpx;
  gap: 8rpx;
}

.day-count {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

.day-total {
  font-size: var(--font-base);
  font-weight: 700;
  color: var(--color-primary);
}

/* -- 时间线组 -- */
.timeline-group {
  margin-left: 8rpx;
  margin-bottom: 16rpx;
}

.tl-track {
  margin-left: 8rpx;
  border-left: 4rpx solid rgba(52, 199, 89, 0.15);
  padding-left: 0;
}

.timeline-item {
  display: flex;
  align-items: flex-start;
  padding: 0 0 0 12rpx;
  position: relative;
  margin-bottom: 12rpx;
  transition: opacity 150ms ease;
}

.timeline-item:active {
  opacity: 0.7;
}


/* 左侧轨道（圆点） */
.tl-rail {
  width: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  position: relative;
  margin-left: -18rpx;
  padding-top: 20rpx;
}

.tl-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--color-primary);
  flex-shrink: 0;
  position: relative;
  z-index: 1;
  border: 3rpx solid #FFFFFF;
  box-shadow: 0 0 0 2rpx rgba(52, 199, 89, 0.2);
}

.tl-line {
  display: none;
}

/* 时间 */
.tl-time {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  width: 72rpx;
  flex-shrink: 0;
  padding-top: 20rpx;
  text-align: center;
  margin-right: 12rpx;
}

/* 内容区 */
.tl-content {
  flex: 1;
  background: var(--bg-card);
  border-radius: var(--border-radius-md);
  padding: 24rpx;
  min-width: 0;
  box-shadow: var(--shadow-sm);
}

.tl-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.tl-cat {
  display: flex;
  align-items: center;
}

.tl-cat-icon {
  font-size: var(--font-md);
  margin-right: 8rpx;
}

.tl-cat-name {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--text-primary);
}

.tl-amount {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--color-primary);
  flex-shrink: 0;
  margin-left: 16rpx;
}

.tl-note {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  display: block;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tl-meta {
  margin-top: 8rpx;
}

.tl-payer {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
}

/* ============================================
   待整理列表
   ============================================ */
.inbox-list {
  padding: 24rpx;
}

.inbox-card {
  display: flex;
  align-items: center;
  background: white;
  border-radius: var(--border-radius-lg);
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
}

.inbox-thumb-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--border-radius-sm);
  margin-right: 20rpx;
  flex-shrink: 0;
  background: #F2F2F7;
  display: flex;
  align-items: center;
  justify-content: center;
}

.inbox-thumb-emoji {
  font-size: var(--font-xl);
  opacity: 0.5;
}

.inbox-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.inbox-status {
  font-size: var(--font-base);
  color: var(--text-secondary);
}

.inbox-status.processing {
  color: var(--color-info);
}

.inbox-status.error {
  color: var(--color-danger);
}

.inbox-amount {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-primary);
}

.inbox-amount.low-confidence {
  color: var(--color-danger);
}

.inbox-category {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.inbox-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}

.action-btn {
  padding: 10rpx 28rpx;
  border-radius: 32rpx;
  font-size: var(--font-sm);
  text-align: center;
}

.action-btn.confirm {
  background: var(--color-primary);
  color: white;
}

.action-btn.reject {
  background: #FFF0F0;
  color: var(--color-danger);
}

.action-btn.retry {
  background: #F0F5FF;
  color: var(--color-info);
}

/* ============================================
   结算页面
   ============================================ */
.settle-container {
  padding: 32rpx 24rpx;
}

.settle-title {
  display: block;
  text-align: center;
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.settle-subtitle {
  display: block;
  text-align: center;
  font-size: var(--font-base);
  color: var(--text-secondary);
  margin-bottom: 40rpx;
}

.transfer-card {
  background: white;
  border-radius: var(--border-radius-xl);
  padding: 36rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-md);
}

.transfer-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.transfer-person {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.person-label {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.person-name {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
}

.transfer-arrow {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin: 0 20rpx;
}

.arrow-text {
  color: white;
  font-size: var(--font-lg);
  font-weight: 700;
}


.transfer-actions {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin-top: 16rpx;
}

.btn-mark-paid,
.btn-forgive {
  flex: 1;
  padding: 18rpx 0;
  border-radius: 40rpx;
  font-size: var(--font-base);
  text-align: center;
  line-height: 1.4;
}

.btn-mark-paid {
  background: #F2F2F7;
  color: var(--text-primary);
}

.btn-forgive {
  border: 2rpx solid var(--color-primary);
  color: var(--color-primary);
  background: transparent;
}

.paid-tag {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: var(--font-base);
  color: var(--color-success);
  font-weight: 500;
}

/* 结算状态行 */
.transfer-status {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.status-tag {
  font-size: var(--font-base);
  font-weight: 500;
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
}

.status-paid { color: var(--color-success); background: rgba(52,199,89,0.1); }
.status-forgiven { color: var(--text-tertiary); background: var(--bg-primary); }

.undo-btn {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  padding: 8rpx 20rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 24rpx;
}

.transfer-card.card-done { opacity: 0.7; }

/* 每张转账卡片的金额行 */
.amount-row {
  display: flex; align-items: center; justify-content: space-between;
  margin: 24rpx 0 8rpx;
  padding: 20rpx 24rpx;
  background: var(--bg-primary);
  border-radius: var(--border-radius-md);
}
.amount-info { display: flex; flex-direction: column; }
.amount-total-label { font-size: var(--font-xs); color: var(--text-tertiary); }
.amount-total-value { font-size: var(--font-lg); font-weight: 700; color: var(--text-primary); }

.amount-settled-hint {
  font-size: var(--font-xs);
  color: var(--color-success);
  margin-top: 4rpx;
}

.amount-pending, .amount-settled { display: flex; flex-direction: column; align-items: flex-end; }
.pending-label, .settled-label, .forgiven-label { font-size: var(--font-xs); color: var(--text-tertiary); }
.pending-value { font-size: var(--font-lg); font-weight: 700; color: var(--color-primary); }
.settled-value { font-size: var(--font-lg); font-weight: 700; color: var(--color-success); }
.forgiven-value { font-size: var(--font-lg); font-weight: 700; color: var(--text-tertiary); }

