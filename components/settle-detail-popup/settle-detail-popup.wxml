<!-- 结算明细弹窗 -->
<view class="popup-mask {{visible ? 'show' : ''}}" bindtap="onClose" catchtouchmove="preventMove"></view>

<view class="popup-container {{visible ? 'show' : ''}}">
  <!-- 关闭按钮 -->
  <view class="close-btn" bindtap="onClose">
    <view class="icon-close"></view>
  </view>

  <block wx:if="{{detail && detail.transfer}}">
    <!-- 转账摘要 -->
    <view class="summary-row">
      <view class="summary-person">
        <text class="summary-name">{{detail.transfer.from_name}}</text>
        <text class="summary-role">付款</text>
      </view>
      <view class="summary-arrow">
        <view class="icon-arrow-right"></view>
      </view>
      <view class="summary-person">
        <text class="summary-name">{{detail.transfer.to_name}}</text>
        <text class="summary-role">收款</text>
      </view>
    </view>

    <!-- 金额 -->
    <view class="amount-breakdown">
      <view class="amount-line total">
        <text class="amount-label">转账金额</text>
        <text class="amount-value">{{detail.transfer.amountDisplay}}</text>
      </view>
    </view>

    <!-- 每人收支表 -->
    <view class="balance-section" wx:if="{{detail.memberSummary.length > 0}}">
      <text class="section-title">每人收支明细</text>
      <view class="balance-table">
        <!-- 表头 -->
        <view class="balance-header">
          <text class="col-name">成员</text>
          <text class="col-num">实付</text>
          <text class="col-num">应付</text>
          <text class="col-num">净额</text>
        </view>
        <!-- 数据行 -->
        <view class="balance-row" wx:for="{{detail.memberSummary}}" wx:key="id">
          <text class="col-name">{{item.name}}</text>
          <text class="col-num">{{item.paidDisplay}}</text>
          <text class="col-num">{{item.shareDisplay}}</text>
          <text class="col-net positive" wx:if="{{item.net > 0}}">+{{item.netDisplay}}</text>
          <text class="col-net negative" wx:elif="{{item.net < 0}}">-{{item.netDisplay}}</text>
          <text class="col-net" wx:else>0</text>
        </view>
      </view>
    </view>

    <!-- 计算说明 -->
    <view class="explain-card">
      <text class="explain-text">净额 = 实付 - 应付。正数表示应收款，负数表示应付款。结算方案为最少转账次数的最优路径。</text>
    </view>
  </block>
</view>
