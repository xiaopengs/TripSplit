/* 结算明细弹窗 */

/* 遮罩层 */
.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--bg-mask);
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
  transition: opacity var(--duration-normal) ease;
}

.popup-mask.show {
  opacity: 1;
  pointer-events: auto;
}

/* 弹窗容器 */
.popup-container {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FFFFFF;
  border-radius: var(--border-radius-xl) var(--border-radius-xl) 0 0;
  z-index: 1001;
  max-height: 75vh;
  padding: 0 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  transform: translateY(100%);
  transition: transform 300ms var(--ease-out);
  box-shadow: var(--shadow-lg);
}

.popup-container.show {
  transform: translateY(0);
}

/* 关闭按钮 */
.close-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-tertiary);
  font-size: var(--font-lg);
  margin-top: 20rpx;
  margin-left: auto;
  border-radius: 50%;
  background: var(--bg-primary);
  flex-shrink: 0;
}

/* 转账摘要 */
.summary-row {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
}

.summary-person {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.summary-name {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
}

.summary-role {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  margin-top: 4rpx;
}

.summary-arrow {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--color-primary);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-base);
  font-weight: 700;
  flex-shrink: 0;
  margin: 0 20rpx;
}

/* 金额分解 */
.amount-breakdown {
  background: var(--bg-primary);
  border-radius: var(--border-radius-md);
  padding: 16rpx 24rpx;
  margin-bottom: 24rpx;
}

.amount-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.amount-line.total {
  border-top: 1rpx solid var(--border-color);
  margin-top: 8rpx;
  padding-top: 16rpx;
}

.amount-label {
  font-size: var(--font-base);
  color: var(--text-secondary);
}

.amount-value {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--text-primary);
}

.amount-value.settled {
  color: var(--color-success);
}

.amount-value.pending {
  color: var(--color-primary);
}

/* 每人收支表 */
.balance-section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 12rpx;
}

.balance-table {
  background: var(--bg-primary);
  border-radius: var(--border-radius-md);
  padding: 8rpx 16rpx;
}

.balance-header {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.balance-header text {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  font-weight: 500;
}

.balance-row {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
}

.balance-row + .balance-row {
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
}

.col-name {
  flex: 1.2;
  font-size: var(--font-sm);
  color: var(--text-primary);
  font-weight: 500;
}

.col-num {
  flex: 1;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  text-align: right;
}

.col-net {
  flex: 1;
  font-size: var(--font-sm);
  font-weight: 600;
  text-align: right;
  color: var(--text-secondary);
}

.col-net.positive {
  color: var(--color-success);
}

.col-net.negative {
  color: var(--color-danger);
}

/* 计算说明 */
.explain-card {
  background: var(--bg-primary);
  border-radius: var(--border-radius-md);
  padding: 16rpx 24rpx;
}

.explain-text {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  line-height: 1.6;
}
