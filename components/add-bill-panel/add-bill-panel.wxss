/* === 手动记账面板样式 === */

/* 遮罩层 */
.panel-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
  transition: opacity 250ms ease;
}

.panel-mask.show {
  opacity: 1;
  pointer-events: auto;
}

/* 面板容器：近全屏底部弹出 */
.panel {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 0;
  height: 88vh;
  background: var(--bg-card);
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1001;
  display: flex;
  flex-direction: column;
  width: auto;
  max-width: calc(100vw - 48rpx);
  transform: translateY(100%);
  transition: transform 280ms var(--ease-out);
  overflow: hidden;
}

.panel.show {
  transform: translateY(0);
}

/* === 头部 === */
.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--border-color);
  flex-shrink: 0;
}

.panel-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.close-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--bg-primary);
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-btn-hover {
  opacity: 0.7;
}

.close-icon {
  color: var(--text-secondary);
  font-size: 28rpx;
  line-height: 1;
}

/* === 滚动内容区 === */
.panel-body {
  flex: 1;
  min-width: 0;
  width: 100%;
  overflow-x: hidden;
  overflow-y: auto;
  padding: 0 32rpx;
  box-sizing: border-box;
}

/* === 金额显示 === */
.amount-display {
  display: flex;
  align-items: baseline;
  justify-content: center;
  padding: 40rpx 0 28rpx;
}

.amount-symbol {
  font-size: 36rpx;
  font-weight: 500;
  color: var(--color-primary);
  margin-right: 8rpx;
}

.amount-value {
  font-size: 72rpx;
  font-weight: 700;
  color: var(--color-primary);
  font-family: -apple-system, 'SF Mono', 'Menlo', monospace;
  line-height: 1;
}

/* === 区块通用 === */
.section {
  margin-bottom: 28rpx;
  min-width: 0;
  box-sizing: border-box;
}

.section-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 16rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

/* 分摊模式切换标签 */
.split-mode-tag {
  padding: 8rpx 20rpx;
  background: var(--bg-primary);
  border-radius: 20rpx;
}

.tag-hover {
  opacity: 0.7;
}

.split-mode-text {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 500;
}

/* === 类目网格（3x2） === */
.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-tile {
  width: calc((100% - 32rpx) / 3);
  aspect-ratio: 1.2;
  border-radius: var(--border-radius-md);
  background: var(--bg-primary);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 3rpx solid transparent;
  transition: all 200ms ease;
}

.tile-hover {
  opacity: 0.7;
}

/* 选中态：绿色边框 + 发光效果 */
.category-tile.active {
  background: rgba(52, 199, 89, 0.08);
  border-color: var(--color-primary);
  box-shadow: 0 0 0 4rpx rgba(52, 199, 89, 0.15), 0 0 16rpx rgba(52, 199, 89, 0.1);
}

.cat-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.cat-name {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.category-tile.active .cat-name {
  color: var(--color-primary);
  font-weight: 600;
}

/* === 成员头像（水平列表） === */
.member-avatars {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.member-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: var(--bg-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  border: 3rpx solid transparent;
  transition: all 150ms ease;
}

.avatar-hover {
  opacity: 0.7;
}

/* 选中态：绿色边框 */
.member-avatar.selected {
  border-color: var(--color-primary);
  background: rgba(52, 199, 89, 0.08);
}

/* 影子成员半透明 */
.member-avatar.shadow {
  opacity: 0.7;
}

.avatar-char {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-secondary);
}

.member-avatar.selected .avatar-char {
  color: var(--color-primary);
}

/* 绿色勾标记 */
.check-badge {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  width: 28rpx;
  height: 28rpx;
  background: var(--color-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #FFFFFF;
}

.check-icon {
  color: #FFFFFF;
  font-size: 16rpx;
  font-weight: 700;
  line-height: 1;
}

/* 影子成员标记 */
.shadow-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  background: #FFCC00;
  border-radius: 10rpx;
  padding: 0 8rpx;
  line-height: 24rpx;
  border: 2rpx solid #FFFFFF;
}

.shadow-text {
  color: #8B6914;
  font-size: 16rpx;
  font-weight: 600;
}

/* 均分预览 */
.share-preview {
  width: 100%;
  text-align: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed var(--border-color);
}

.share-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* === 自定义分摊 === */
.custom-splits {
  background: var(--bg-primary);
  border-radius: var(--border-radius-md);
  padding: 16rpx;
  min-width: 0;
  box-sizing: border-box;
}

.custom-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--border-color);
  min-width: 0;
  box-sizing: border-box;
}

.cs-name {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 28rpx;
  color: var(--text-primary);
  flex: 1;
  box-sizing: border-box;
}

.custom-row:last-child {
  border-bottom: none;
}

.cs-input {
  width: 200rpx;
  text-align: right;
  font-size: 28rpx;
  padding: 8rpx 16rpx;
  background: #FFFFFF;
  border-radius: var(--border-radius-sm);
  border: 1rpx solid var(--border-color);
  box-sizing: border-box;
  flex-shrink: 0;
  min-width: 0;
}

/* === 备注输入 === */
.note-input {
  width: 100%;
  padding: 20rpx 24rpx;
  background: var(--bg-primary);
  border-radius: var(--border-radius-md);
  font-size: 28rpx;
  box-sizing: border-box;
  height: 80rpx;
  line-height: 1.4;
}

/* === 图片上传 === */
.image-area {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
  align-items: center;
}

.image-list {
  display: flex;
  gap: 12rpx;
}

.upload-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--border-radius-sm);
  background: var(--bg-primary);
}

.add-image-btn {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--border-radius-sm);
  border: 2rpx dashed var(--border-color);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-primary);
}

.add-image-hover {
  opacity: 0.6;
}

.add-image-icon {
  color: var(--text-tertiary);
  font-size: 48rpx;
  line-height: 1;
}

/* === 底部区域 === */
.panel-footer {
  flex-shrink: 0;
  background: var(--bg-card);
  border-top: 1rpx solid var(--border-color);
}

/* 提交按钮行 */
.submit-row {
  padding: 16rpx 24rpx 12rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: var(--color-primary);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(52, 199, 89, 0.3);
  transition: all 150ms ease;
}

.submit-btn.disabled {
  background: #C8C8CC;
  box-shadow: none;
  pointer-events: none;
}

.submit-hover {
  opacity: 0.85;
  transform: scale(0.98);
}

.submit-text {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
}
