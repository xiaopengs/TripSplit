/* === 手动记账面板样式 === */

/* 遮罩层 */
.panel-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
  transition: opacity 250ms ease;
}

.panel-mask.show {
  opacity: 1;
  pointer-events: auto;
}

/* 面板容器 */
.panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 85vh;
  background: var(--bg-card);
  border-radius: var(--border-radius-xl) var(--border-radius-xl) 0 0;
  z-index: 1001;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 280ms var(--ease-out);
  overflow: hidden;
}

.panel.show {
  transform: translateY(0);
}

/* === 头部 === */
.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--border-color);
  flex-shrink: 0;
}

.panel-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
}

.close-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--bg-primary);
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-btn-hover {
  opacity: 0.7;
}

.close-icon {
  color: var(--text-secondary);
  font-size: var(--font-base);
  line-height: 1;
}

/* === 滚动内容区 === */
.panel-body {
  flex: 1;
  min-width: 0;
  width: 100%;
  overflow-x: hidden;
  overflow-y: auto;
  padding: 0 32rpx;
  box-sizing: border-box;
}

/* === 金额显示 === */
.amount-display {
  display: flex;
  align-items: baseline;
  justify-content: center;
  padding: 32rpx 0 20rpx;
}

.amount-symbol {
  font-size: var(--font-lg);
  font-weight: 500;
  color: var(--color-primary);
  margin-right: 8rpx;
}

.amount-value {
  font-size: var(--font-xxl);
  font-weight: 700;
  color: var(--color-primary);
  font-family: -apple-system, 'SF Mono', 'Menlo', monospace;
  line-height: 1;
}

/* === 区块通用 === */
.section {
  margin-bottom: 24rpx;
  min-width: 0;
  box-sizing: border-box;
}

.section-label {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  display: block;
  margin-bottom: 12rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.split-mode-tabs {
  display: flex;
  background: var(--bg-primary);
  border-radius: 20rpx;
  padding: 4rpx;
}

.mode-tab {
  padding: 14rpx 32rpx;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  border-radius: 18rpx;
  transition: all var(--duration-fast) ease;
}

.mode-tab.active {
  background: var(--bg-card);
  color: var(--color-primary);
  font-weight: 600;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.08);
}

/* === 类目横向滚动 chip 样式 === */
.category-scroll {
  width: 100%;
  white-space: nowrap;
}

.category-chips {
  display: inline-flex;
  gap: 12rpx;
  padding-bottom: 4rpx;
}

.cat-chip {
  display: inline-flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-radius: 32rpx;
  background: var(--bg-primary);
  border: 2rpx solid transparent;
  transition: all 180ms ease;
  flex-shrink: 0;
}

.chip-hover {
  opacity: 0.7;
}

.cat-chip.active {
  background: rgba(52, 199, 89, 0.08);
  border-color: var(--color-primary);
}

.chip-icon {
  font-size: var(--font-base);
  margin-right: 6rpx;
}

.chip-text {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  font-weight: 500;
}

.cat-chip.active .chip-text {
  color: var(--color-primary);
  font-weight: 600;
}

/* 自定义类目名称输入 */
.custom-cat-input {
  width: 100%;
  padding: 16rpx 24rpx;
  background: var(--bg-primary);
  border-radius: var(--border-radius-md);
  font-size: var(--font-base);
  margin-top: 12rpx;
  box-sizing: border-box;
  height: 72rpx;
}

/* === 快捷标签 === */
.tags-scroll {
  width: 100%;
  white-space: nowrap;
}

.quick-tags {
  display: inline-flex;
  gap: 12rpx;
}

.qtag {
  display: inline-flex;
  align-items: center;
  padding: 18rpx 28rpx;
  border-radius: 24rpx;
  background: var(--color-tag-bg);
  border: 1rpx solid var(--color-tag-border);
  flex-shrink: 0;
}

.qtag-hover {
  background: #FFE0B2;
}

.qtag-text {
  font-size: var(--font-sm);
  color: var(--color-tag-text);
  font-weight: 500;
}

.qtag.active {
  background: #FFCC80;
  border-color: #FF9800;
}

.qtag.active .qtag-text {
  color: #BF360C;
  font-weight: 600;
}

/* === 时间 & 位置 === */
.meta-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  flex: 1;
  background: var(--bg-primary);
  border-radius: var(--border-radius-md);
  padding: 14rpx 20rpx;
}

.meta-icon {
  font-size: var(--font-base);
  margin-right: 12rpx;
  flex-shrink: 0;
}

.meta-value {
  font-size: var(--font-base);
  color: var(--text-primary);
  font-weight: 500;
}

.meta-time {
  font-size: var(--font-base);
  color: var(--text-secondary);
}

.meta-datetime-sep {
  width: 1rpx;
  height: 28rpx;
  background: var(--border-color);
  margin: 0 20rpx;
  flex-shrink: 0;
}

.meta-time-value {
  color: var(--text-primary);
  font-weight: 500;
}

/* 位置 - 点击定位入口 */
.loc-trigger {
  display: flex;
  align-items: center;
  background: var(--bg-primary);
  border-radius: var(--border-radius-md);
  padding: 20rpx 24rpx;
}

.loc-trigger-hover {
  opacity: 0.7;
}

.loc-trigger-icon {
  font-size: var(--font-md);
  margin-right: 12rpx;
}

.loc-trigger-text {
  font-size: var(--font-base);
  color: var(--text-secondary);
  flex: 1;
}

.loc-trigger-text.loading {
  color: var(--text-tertiary);
}

.loc-trigger-arrow {
  font-size: var(--font-md);
  color: var(--text-tertiary);
  font-weight: 500;
}

/* 位置 - 已选标签行 */
.loc-tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

/* 位置 - 标签 */
.loc-tag {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 24rpx;
  background: var(--bg-primary);
  border-radius: 32rpx;
  border: 1rpx solid transparent;
  flex-shrink: 0;
}

.loc-tag.active {
  background: rgba(52, 199, 89, 0.08);
  border-color: var(--color-primary);
}

.loc-tag-hover {
  opacity: 0.7;
}

.loc-tag-icon {
  font-size: var(--font-sm);
  margin-right: 8rpx;
}

.loc-tag-text {
  font-size: var(--font-sm);
  color: var(--text-primary);
  font-weight: 500;
}

.loc-tag.active .loc-tag-text {
  color: var(--color-primary);
  font-weight: 600;
}

.loc-tag-clear {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
  margin-left: 12rpx;
  padding: 4rpx 8rpx;
}

/* 位置 - 附近位置横向滚动 */
.loc-tags-scroll {
  width: 100%;
  white-space: nowrap;
  margin-top: 12rpx;
}

.loc-tags-row {
  display: inline-flex;
  gap: 12rpx;
}

/* === 付款人选择 === */
.payer-avatars {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.payer-avatar {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.payer-hover {
  opacity: 0.7;
}

.payer-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--bg-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid transparent;
  position: relative;
  transition: all var(--duration-fast) ease;
}

.payer-circle.payer-active {
  background: var(--color-info) !important;
  border-color: var(--color-info) !important;
  box-shadow: 0 4rpx 12rpx rgba(0, 122, 255, 0.3);
}

.payer-char {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--text-secondary);
  transition: color var(--duration-fast) ease;
}

.payer-circle.payer-active .payer-char {
  color: var(--text-white) !important;
}

.payer-name {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  margin-top: 6rpx;
  max-width: 88rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
  transition: color var(--duration-fast) ease;
}

.payer-name.selected {
  color: var(--color-info) !important;
  font-weight: 600;
}

/* === 成员头像 === */
.member-avatars {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.member-avatar {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  transition: all 150ms ease;
}

.avatar-hover {
  opacity: 0.7;
}

.avatar-circle {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: var(--bg-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid transparent;
  position: relative;
  transition: all var(--duration-fast) ease;
}

.avatar-circle.selected {
  background: var(--color-primary) !important;
  border-color: var(--color-primary) !important;
  box-shadow: 0 4rpx 12rpx rgba(52, 199, 89, 0.3);
}

.member-avatar.shadow {
  opacity: 0.7;
}

.avatar-char {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-secondary);
  transition: color 150ms ease;
}

.avatar-circle.selected .avatar-char {
  color: var(--text-white) !important;
}

.avatar-name {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  margin-top: 6rpx;
  max-width: 96rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
  transition: color 150ms ease;
}

.avatar-name.selected {
  color: var(--color-primary) !important;
  font-weight: 600;
}

.check-badge {
  position: absolute;
  bottom: -2rpx;
  right: -2rpx;
  width: 28rpx;
  height: 28rpx;
  background: var(--bg-card);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid var(--color-primary);
}

.check-icon {
  color: var(--color-primary);
  font-size: 16rpx;
  font-weight: 700;
  line-height: 1;
}

.shadow-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  background: var(--color-warning);
  border-radius: 10rpx;
  padding: 0 8rpx;
  line-height: 24rpx;
  border: 2rpx solid var(--bg-card);
}

.shadow-text {
  color: var(--color-shadow-text);
  font-size: 16rpx;
  font-weight: 600;
}

/* 均分预览 */
.share-preview {
  width: 100%;
  text-align: center;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx dashed var(--border-color);
}

.share-text {
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

/* === 自定义分摊 === */
.custom-splits {
  background: var(--bg-primary);
  border-radius: var(--border-radius-md);
  padding: 12rpx 16rpx;
  min-width: 0;
  box-sizing: border-box;
}

.custom-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-color);
  min-width: 0;
  box-sizing: border-box;
}

.cs-name {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: var(--font-base);
  color: var(--text-primary);
  flex: 1;
  box-sizing: border-box;
}

.custom-row:last-child {
  border-bottom: none;
}

.cs-input {
  width: 200rpx;
  height: 64rpx;
  text-align: right;
  font-size: var(--font-base);
  padding: 0 16rpx;
  background: var(--bg-card);
  border-radius: var(--border-radius-sm);
  border: 1rpx solid var(--border-color);
  box-sizing: border-box;
  flex-shrink: 0;
  min-width: 0;
  line-height: 64rpx;
}

/* 自动计算的金额显示 */
.cs-auto {
  width: 200rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 0 16rpx;
  background: rgba(52, 199, 89, 0.06);
  border-radius: var(--border-radius-sm);
  border: 1rpx solid rgba(52, 199, 89, 0.2);
  box-sizing: border-box;
  flex-shrink: 0;
}

.cs-auto-value {
  font-size: var(--font-base);
  color: var(--color-primary);
  font-weight: 600;
}

/* === 备注输入 === */
.note-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.note-input {
  flex: 1;
  padding: 16rpx 24rpx;
  background: var(--bg-primary);
  border-radius: var(--border-radius-sm);
  font-size: var(--font-base);
  box-sizing: border-box;
  height: 72rpx;
  line-height: 1.4;
}

.note-image-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  background: var(--bg-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.note-image-btn-hover {
  background: var(--border-color);
}

.note-image-icon {
  font-size: var(--font-md);
  opacity: 0.5;
}

.note-thumbs {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
  position: relative;
}

.note-thumb {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
}

.note-thumb-remove {
  position: relative;
}

.note-thumb-remove-icon {
  display: none;
}

/* === 底部区域 === */
.panel-footer {
  flex-shrink: 0;
  background: var(--bg-card);
  border-top: 1rpx solid var(--border-color);
}

.submit-row {
  padding: 16rpx 24rpx 12rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: var(--color-primary);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(52, 199, 89, 0.3);
  transition: all 150ms ease;
}

.submit-btn.disabled {
  background: #C8C8CC;
  box-shadow: none;
  pointer-events: none;
}

.submit-hover {
  opacity: 0.85;
  transform: scale(0.98);
}

.submit-text {
  color: var(--text-white);
  font-size: var(--font-md);
  font-weight: 600;
}
