/* 账单详情弹窗样式 */
.popup-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: var(--bg-mask);
  z-index: 1000;
}

.popup-container {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1001;
  max-height: 85vh;
  padding: 0 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  overflow-y: auto;
  transform: translateY(100%);
  transition: transform 250ms var(--ease-out);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.popup-container.show {
  transform: translateY(0);
}

.close-btn {
  align-self: flex-end;
  width: 56rpx; height: 56rpx;
  display: flex; align-items: center; justify-content: center;
  color: var(--text-secondary);
  font-size: 32rpx;
  margin-top: 16rpx;
  margin-bottom: 8rpx;
}

.detail-icon-wrap {
  width: 120rpx; height: 120rpx;
  border-radius: var(--border-radius-xl);
  background: var(--bg-primary);
  display: flex; align-items: center; justify-content: center;
  margin: 16rpx 0 24rpx;
}

.detail-icon {
  font-size: 60rpx;
}

.detail-amount {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.detail-category {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.detail-note {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 12rpx;
  text-align: center;
  max-width: 80%;
}

/* 信息行 */
.info-section {
  width: 100%;
  margin-top: 32rpx;
  padding: 24rpx;
  background: var(--bg-primary);
  border-radius: var(--border-radius-lg);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
}

.info-row + .info-row {
  border-top: 1rpx solid var(--border-color);
}

.info-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.info-value {
  font-size: 26rpx;
  color: var(--text-primary);
}

/* 分摊明细 */
.split-section {
  width: 100%;
  margin-top: 24rpx;
}

.split-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 12rpx;
}

.split-list {
  background: var(--bg-primary);
  border-radius: var(--border-radius-lg);
  padding: 8rpx 24rpx;
}

.split-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.split-item + .split-item {
  border-top: 1rpx solid var(--border-color);
}

.split-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.split-name {
  font-size: 28rpx;
  color: var(--text-primary);
}

.shadow-label {
  font-size: 18rpx;
  background: #FFE4A0;
  color: #8B6914;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
}

.split-share {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.split-total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0 8rpx;
  margin-top: 8rpx;
}

.total-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.total-value {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-primary);
}

/* 图片 */
.images-section {
  width: 100%;
  margin-top: 24rpx;
}

.images-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 12rpx;
}

.images-list {
  display: flex;
  gap: 12rpx;
}

.detail-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: var(--border-radius-md);
}

/* 操作按钮 */
.action-section {
  width: 100%;
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
}

.btn-edit, .btn-delete {
  flex: 1;
  padding: 20rpx 0;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
}

.btn-edit {
  background: var(--bg-primary);
  color: var(--text-primary);
}

.btn-delete {
  background: #FFF0F0;
  color: var(--color-danger);
}
