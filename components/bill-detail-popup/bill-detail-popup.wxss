/* ============================================
   账单详情弹窗样式
   ============================================ */

/* 遮罩层 */
.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--bg-mask);
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
  transition: opacity var(--duration-normal) ease;
}

.popup-mask.show {
  opacity: 1;
  pointer-events: auto;
}

/* 弹窗容器 — 底部半屏弹出 */
.popup-container {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1001;
  max-height: 85vh;
  padding: 0 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  transform: translateY(100%);
  transition: transform 300ms var(--ease-out);
  display: flex;
  flex-direction: column;
  align-items: stretch;
  box-shadow: var(--shadow-lg);
}

.popup-container.show {
  transform: translateY(0);
}

/* ---- 关闭按钮 ---- */
.close-btn {
  order: 0;
  align-self: flex-end;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-tertiary);
  font-size: var(--font-lg);
  margin-top: 20rpx;
  margin-bottom: 4rpx;
  border-radius: 50%;
  background: var(--bg-primary);
  flex-shrink: 0;
}

/* ---- 类目图标区域 ---- */
.detail-icon-wrap {
  order: 1;
  width: 136rpx;
  height: 136rpx;
  border-radius: var(--border-radius-xl);
  background: rgba(52, 199, 89, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 8rpx 0 12rpx;
  flex-shrink: 0;
}

.detail-icon {
  font-size: var(--font-xxl);
}

/* ---- 类目名称（通过 order 排在图标下方、金额上方）---- */
.detail-category {
  order: 2;
  font-size: var(--font-base);
  color: var(--text-secondary);
  margin-top: 4rpx;
  margin-bottom: 12rpx;
}

/* ---- 金额 — 64rpx 加粗绿色主色 ---- */
.detail-amount {
  order: 3;
  font-size: var(--font-xxl);
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1.2;
}

/* ---- 备注 ---- */
.detail-note {
  order: 4;
  font-size: var(--font-base);
  color: var(--text-secondary);
  margin-top: 12rpx;
  text-align: center;
  max-width: 80%;
  padding: 8rpx 28rpx;
  background: var(--bg-primary);
  border-radius: 24rpx;
}

/* ============================================
   信息区块
   ============================================ */
.info-section {
  order: 5;
  width: 100%;
  margin-top: 36rpx;
  padding: 0;
  background: transparent;
  border-radius: 0;
  min-width: 0;
  box-sizing: border-box;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 0;
  min-width: 0;
  box-sizing: border-box;
}

.info-row + .info-row {
  border-top: 1rpx solid var(--border-color);
}

.info-label {
  font-size: var(--font-base);
  color: var(--text-secondary);
  flex-shrink: 0;
}

.info-value {
  font-size: var(--font-base);
  color: var(--text-primary);
  font-weight: 500;
  text-align: right;
}

/* ============================================
   分摊明细
   ============================================ */
.split-section {
  order: 6;
  width: 100%;
  margin-top: 32rpx;
  min-width: 0;
  box-sizing: border-box;
}

.split-title {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 16rpx;
}

.split-list {
  background: var(--bg-primary);
  border-radius: var(--border-radius-lg);
  padding: 4rpx 28rpx;
}

.split-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 0;
  min-width: 0;
  box-sizing: border-box;
}

.split-item + .split-item {
  border-top: 1rpx solid var(--border-color);
}

.split-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.split-name {
  font-size: var(--font-base);
  color: var(--text-primary);
}

/* 影子成员标签 — 黄底深色文字 */
.shadow-label {
  font-size: var(--font-xs);
  background: var(--color-shadow-bg);
  color: var(--color-shadow-text);
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
  line-height: 1.6;
}

.split-share {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--text-primary);
}

/* 合计行 */
.split-total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0 8rpx;
  margin-top: 8rpx;
  border-top: 2rpx solid var(--border-color);
}

.total-label {
  font-size: var(--font-base);
  color: var(--text-secondary);
  font-weight: 500;
}

.total-value {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--color-primary);
}

/* ============================================
   附件图片
   ============================================ */
.images-section {
  order: 7;
  width: 100%;
  margin-top: 32rpx;
  min-width: 0;
  box-sizing: border-box;
}

.images-title {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 16rpx;
}

.images-list {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.detail-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: var(--border-radius-md);
}

/* ============================================
   操作按钮
   ============================================ */
.action-section {
  order: 8;
  width: 100%;
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
  flex-shrink: 0;
  min-width: 0;
  box-sizing: border-box;
}

.btn-edit,
.btn-delete {
  flex: 1;
  padding: 24rpx 0;
  border-radius: 48rpx;
  font-size: var(--font-md);
  font-weight: 600;
  text-align: center;
  line-height: 1;
}

.btn-edit {
  background: var(--bg-primary);
  color: var(--text-primary);
}

.btn-delete {
  background: rgba(255, 59, 48, 0.1);
  color: var(--color-danger);
}
