/* ============================================
   成员管理弹窗样式
   ============================================ */

/* 遮罩层 */
.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--bg-mask);
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
  transition: opacity var(--duration-normal) ease;
}

.popup-mask.show {
  opacity: 1;
  pointer-events: auto;
}

/* 弹窗容器 — 大面积底部弹出 ~85vh */
.popup-container {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FFFFFF;
  border-radius: var(--border-radius-xl) var(--border-radius-xl) 0 0;
  z-index: 1001;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 300ms var(--ease-out);
  box-shadow: var(--shadow-lg);
}

.popup-container.show {
  transform: translateY(0);
}

/* ---- 标题栏 ---- */
.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid var(--border-color);
  flex-shrink: 0;
}

.popup-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
}

.close-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-tertiary);
  font-size: var(--font-lg);
  border-radius: 50%;
  background: var(--bg-primary);
}

/* ---- 可滚动内容区 ---- */
.scroll-body {
  flex: 1;
  overflow-x: hidden;
  overflow-y: auto;
  padding: 24rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ============================================
   管理账本入口
   ============================================ */
.manage-books-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: var(--bg-primary);
  border-radius: var(--border-radius-lg);
  margin-bottom: 24rpx;
}

.manage-books-info {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.manage-books-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.manage-books-text {
  flex: 1;
  min-width: 0;
}

.manage-books-title {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.manage-books-desc {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  display: block;
  margin-top: 4rpx;
}

.manage-books-arrow {
  font-size: var(--font-lg);
  color: var(--text-tertiary);
  font-weight: 500;
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* ============================================
   邀请好友卡片
   ============================================ */
.invite-card {
  display: flex !important;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx !important;
  background: rgba(52, 199, 89, 0.06);
  border: 2rpx dashed var(--color-primary) !important;
  border-radius: var(--border-radius-lg);
  margin: 0 0 32rpx 0 !important;
  width: 100% !important;
  min-width: 0;
  box-sizing: border-box;
  text-align: left;
  line-height: 1.5;
  font-size: var(--font-base);
}

/* 覆盖小程序 button 默认伪元素边框 */
.invite-card::after {
  border: none !important;
}

.invite-info {
  flex: 1;
  min-width: 0;
}

.invite-title {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.invite-desc {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  display: block;
  margin-top: 6rpx;
  line-height: 1.5;
}

.share-circle {
  width: 76rpx;
  height: 76rpx;
  background: var(--color-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 20rpx;
}

.share-icon {
  color: #FFFFFF;
  font-size: var(--font-lg);
  font-weight: 700;
}

.share-circle .icon-share {
  color: #FFFFFF;
}

/* ============================================
   区块通用
   ============================================ */
.section {
  margin-bottom: 28rpx;
}

.section-title {
  font-size: var(--font-base);
  font-weight: 600;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 16rpx;
}

.section-title.no-margin {
  margin-bottom: 0;
}

.section-header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.pending-hint {
  font-size: var(--font-sm);
  color: #FF9500;
  font-weight: 500;
}

/* ============================================
   已加入成员卡片
   ============================================ */
.real-member-card {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  min-width: 0;
  box-sizing: border-box;
}

.real-member-card + .real-member-card {
  border-top: 1rpx solid var(--border-color);
}

/* ---- 头像 ---- */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-md);
  font-weight: 700;
  margin-right: 20rpx;
  flex-shrink: 0;
  position: relative;
}

.avatar-real {
  background: var(--color-primary);
  color: #FFFFFF;
}

.avatar-shadow {
  background: #F5F5F5;
  border: 2rpx dashed #D1D1D6;
}

.avatar-shadow .icon-person {
  color: var(--text-secondary);
}

/* "?" 小圆标 */
.question-badge {
  position: absolute;
  bottom: -2rpx;
  right: -2rpx;
  width: 32rpx;
  height: 32rpx;
  background: #FF9500;
  color: #FFFFFF;
  font-size: var(--font-xs);
  font-weight: 700;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #FFFFFF;
}

/* ---- 成员信息 ---- */
.member-body {
  flex: 1;
  min-width: 0;
}

.member-name {
  font-size: var(--font-md);
  font-weight: 500;
  color: var(--text-primary);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.member-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 6rpx;
}

.tag-joined {
  font-size: var(--font-sm);
  color: var(--color-primary);
  font-weight: 500;
}

.tag-role {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
}

/* 影子成员标签 — 黄底深色 */
.tag-shadow {
  font-size: var(--font-xs);
  background: var(--color-shadow-bg);
  color: var(--color-shadow-text);
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  font-weight: 500;
  line-height: 1.4;
}

.shadow-subtitle {
  font-size: var(--font-sm);
  color: var(--color-secondary);
  display: block;
  margin-top: 4rpx;
}

/* ============================================
   影子成员说明卡片
   ============================================ */
.tip-card {
  display: flex;
  padding: 24rpx;
  background: #FFF9E6;
  border-radius: var(--border-radius-lg);
  margin-bottom: 20rpx;
  min-width: 0;
  box-sizing: border-box;
}

.tip-emoji {
  font-size: 40rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  line-height: 1.2;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8B6914;
}

.tip-body {
  flex: 1;
}

.tip-heading {
  font-size: var(--font-base);
  font-weight: 600;
  color: #8B6914;
  display: block;
  margin-bottom: 6rpx;
}

.tip-text {
  font-size: var(--font-sm);
  color: #B8922A;
  display: block;
  line-height: 1.6;
}

/* ============================================
   影子成员卡片
   ============================================ */
.shadow-member-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: var(--color-shadow-bg);
  border: 2rpx dashed var(--color-shadow-border);
  border-radius: var(--border-radius-lg);
  margin-bottom: 12rpx;
  min-width: 0;
  box-sizing: border-box;
}

.shadow-subtitle.claimed {
  color: var(--color-success);
}

/* ============================================
   添加影子成员按钮
   ============================================ */
.add-shadow-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  border: 2rpx dashed var(--border-color);
  border-radius: var(--border-radius-lg);
  color: var(--text-secondary);
  font-size: var(--font-base);
  margin-top: 8rpx;
  margin-bottom: 16rpx;
}
