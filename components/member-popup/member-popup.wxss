/* ============================================
   成员管理弹窗样式
   ============================================ */

/* 遮罩层 */
.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--bg-mask);
  z-index: 1000;
}

/* 弹窗容器 — 大面积底部弹出 ~80vh */
.popup-container {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 0;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1001;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  width: auto;
  max-width: calc(100vw - 48rpx);
  transform: translateY(100%);
  transition: transform 300ms var(--ease-out);
  box-shadow: var(--shadow-lg);
}

.popup-container.show {
  transform: translateY(0);
}

/* ---- 标题栏 ---- */
.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--border-color);
  flex-shrink: 0;
}

.popup-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.close-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-tertiary);
  font-size: 36rpx;
  border-radius: 50%;
  background: var(--bg-primary);
}

/* ---- 可滚动内容区 ---- */
.scroll-body {
  flex: 1;
  overflow: hidden;
  padding: 24rpx 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

/* ============================================
   邀请好友卡片
   ============================================ */
.invite-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  background: rgba(52, 199, 89, 0.06);
  border: 2rpx dashed var(--color-primary);
  border-radius: var(--border-radius-lg);
  margin-bottom: 32rpx;
}

.invite-info {
  flex: 1;
  min-width: 0;
}

.invite-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.invite-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.share-circle {
  width: 76rpx;
  height: 76rpx;
  background: var(--color-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 20rpx;
}

.share-icon {
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: 700;
}

/* ============================================
   区块通用
   ============================================ */
.section {
  margin-bottom: 28rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 16rpx;
}

.section-title.no-margin {
  margin-bottom: 0;
}

.section-header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.pending-hint {
  font-size: 22rpx;
  color: #FF9500;
  font-weight: 500;
}

/* ============================================
   已加入成员卡片
   ============================================ */
.real-member-card {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.real-member-card + .real-member-card {
  border-top: 1rpx solid var(--border-color);
}

/* ---- 头像 ---- */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  margin-right: 20rpx;
  flex-shrink: 0;
  position: relative;
}

.avatar-real {
  background: var(--color-primary);
  color: #FFFFFF;
}

.avatar-shadow {
  background: #F5F5F5;
  border: 2rpx dashed #D1D1D6;
}

.shadow-person {
  font-size: 36rpx;
}

/* "?" 小圆标 */
.question-badge {
  position: absolute;
  bottom: -2rpx;
  right: -2rpx;
  width: 32rpx;
  height: 32rpx;
  background: #FF9500;
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 700;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #FFFFFF;
}

/* ---- 成员信息 ---- */
.member-body {
  flex: 1;
  min-width: 0;
}

.member-name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.member-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 6rpx;
}

.tag-joined {
  font-size: 22rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.tag-role {
  font-size: 20rpx;
  color: var(--text-tertiary);
}

/* 影子成员标签 — 黄底深色 */
.tag-shadow {
  font-size: 20rpx;
  background: #FFF3D0;
  color: #8B6914;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  font-weight: 500;
  line-height: 1.4;
}

.shadow-subtitle {
  font-size: 22rpx;
  color: #FF9500;
  display: block;
  margin-top: 4rpx;
}

/* ============================================
   影子成员说明卡片
   ============================================ */
.tip-card {
  display: flex;
  padding: 24rpx;
  background: #FFF9E6;
  border-radius: var(--border-radius-lg);
  margin-bottom: 20rpx;
}

.tip-emoji {
  font-size: 40rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  line-height: 1.2;
}

.tip-body {
  flex: 1;
}

.tip-heading {
  font-size: 26rpx;
  font-weight: 600;
  color: #8B6914;
  display: block;
  margin-bottom: 6rpx;
}

.tip-text {
  font-size: 22rpx;
  color: #B8922A;
  display: block;
  line-height: 1.6;
}

/* ============================================
   影子成员卡片
   ============================================ */
.shadow-member-card {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  background: #FFFCF0;
  border: 2rpx dashed #FFD966;
  border-radius: var(--border-radius-lg);
  margin-bottom: 12rpx;
}

/* ---- 认领按钮 — 珊瑚粉色 ---- */
.claim-btn {
  padding: 12rpx 28rpx;
  background: #FF6B6B;
  color: #FFFFFF;
  border-radius: 28rpx;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* ============================================
   添加影子成员按钮
   ============================================ */
.add-shadow-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  border: 2rpx dashed var(--border-color);
  border-radius: var(--border-radius-lg);
  color: var(--text-secondary);
  font-size: 28rpx;
  margin-top: 8rpx;
  margin-bottom: 16rpx;
}

/* ============================================
   通用
   ============================================ */
.hover-opacity {
  opacity: 0.7;
}
