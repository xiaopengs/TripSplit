/* 成员管理弹窗样式 */
.popup-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: var(--bg-mask);
  z-index: 1000;
}

.popup-container {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1001;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 250ms var(--ease-out);
}

.popup-container.show {
  transform: translateY(0);
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--border-color);
  flex-shrink: 0;
}

.popup-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.close-btn {
  width: 56rpx; height: 56rpx;
  display: flex; align-items: center; justify-content: center;
  color: var(--text-secondary);
  font-size: 32rpx;
}

/* 邀请区域 */
.invite-section {
  padding: 24rpx 32rpx;
  flex-shrink: 0;
}

.invite-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(52,199,89,0.08), rgba(52,199,89,0.02));
  border: 2rpx dashed var(--color-primary);
  border-radius: var(--border-radius-lg);
}

.invite-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  display: block;
}

.invite-desc {
  font-size: 22rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 4rpx;
}

.share-btn {
  width: 72rpx; height: 72rpx;
  background: var(--color-primary);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.share-icon {
  color: white;
  font-size: 32rpx;
}

/* 滚动区 */
.scroll-area {
  flex: 1;
  overflow-y: auto;
  padding: 0 32rpx 32rpx;
}

/* 区块 */
.section {
  margin-bottom: 24rpx;
}

.section-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 12rpx;
}

.claim-hint {
  font-size: 22rpx;
  color: #FF9500;
}

/* 影子成员说明 */
.shadow-tip-card {
  display: flex;
  padding: 20rpx;
  background: #FFF9E6;
  border-radius: var(--border-radius-md);
  margin-bottom: 16rpx;
}

.tip-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.tip-content {
  flex: 1;
}

.tip-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #8B6914;
  display: block;
}

.tip-desc {
  font-size: 22rpx;
  color: #B8922A;
  margin-top: 4rpx;
  display: block;
  line-height: 1.5;
}

/* 成员项 */
.member-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.member-item:last-child {
  border-bottom: none;
}

.shadow-item {
  background: #FFFBF0;
  margin: 0 -12rpx;
  padding: 20rpx 12rpx;
  border-radius: var(--border-radius-md);
  border: 1rpx solid #FFE4A0;
  border-bottom-color: #FFE4A0;
  margin-bottom: 8rpx;
}

.avatar {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  background: var(--color-primary);
  display: flex; align-items: center; justify-content: center;
  color: white;
  font-size: 28rpx;
  font-weight: 600;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.avatar.shadow {
  background: #E5E5EA;
  color: var(--text-secondary);
  font-size: 28rpx;
}

.member-info {
  flex: 1;
  min-width: 0;
}

.member-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  display: block;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.shadow-tag {
  font-size: 20rpx;
  background: #FFE4A0;
  color: #8B6914;
  padding: 2rpx 10rpx;
  border-radius: 10rpx;
}

.member-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 4rpx;
}

.status-joined {
  font-size: 22rpx;
  color: var(--color-success);
}

.member-status.waiting {
  font-size: 22rpx;
  color: #FF9500;
}

.role-tag {
  font-size: 20rpx;
  color: var(--text-tertiary);
}

.claim-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 10rpx 20rpx;
  background: var(--color-primary);
  color: white;
  border-radius: 24rpx;
  font-size: 22rpx;
  flex-shrink: 0;
}

.claim-icon {
  font-size: 22rpx;
}

/* 添加影子成员 */
.add-shadow-section {
  padding: 16rpx 32rpx 40rpx;
  flex-shrink: 0;
}

.add-shadow-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx;
  border: 2rpx dashed var(--border-color);
  border-radius: var(--border-radius-md);
  color: var(--text-secondary);
  font-size: 26rpx;
}

.add-icon {
  font-size: 28rpx;
}

/* Hover */
.hover-opacity {
  opacity: 0.7;
}
