<!-- 成员管理弹窗 -->
<view class="popup-mask {{visible ? 'show' : ''}}" bindtap="onClose" catchtouchmove="preventMove"></view>

<view class="popup-container {{visible ? 'show' : ''}}">
  <!-- 标题栏 -->
  <view class="popup-header">
    <text class="popup-title">成员管理</text>
    <view class="close-btn" bindtap="onClose"><text>✕</text></view>
  </view>

  <!-- 可滚动内容区 -->
  <scroll-view class="scroll-body" scroll-y enhanced show-scrollbar="{{false}}">

    <!-- 邀请好友卡片 -->
    <button
      class="invite-card"
      hover-class="hover-opacity"
      open-type="share"
      data-book-id="{{bookId}}"
      data-book-name="{{bookName}}"
    >
      <view class="invite-info">
        <text class="invite-title">邀请好友加入账本</text>
        <text class="invite-desc">分享给微信好友，好友可选择身份加入</text>
      </view>
      <view class="share-circle">
        <text class="share-icon">↗</text>
      </view>
    </button>

    <!-- ======== 已加入成员 ======== -->
    <view class="section" wx:if="{{realMembers.length > 0}}">
      <text class="section-title">已加入成员 ({{realMembers.length}})</text>

      <view class="real-member-card" wx:for="{{realMembers}}" wx:key="id">
        <view class="avatar avatar-real">
          <text>{{item.avatar_char}}</text>
        </view>
        <view class="member-body">
          <text class="member-name">{{item.nickname}}</text>
          <view class="member-meta">
            <text class="tag-joined">✓ 已加入</text>
            <text class="tag-role">完整权限</text>
          </view>
        </view>
      </view>
    </view>

    <!-- ======== 影子成员 ======== -->
    <view class="section" wx:if="{{shadowMembers.length > 0}}">
      <view class="section-header-row">
        <text class="section-title no-margin">影子成员 ({{shadowMembers.length}})</text>
        <text class="pending-hint" wx:if="{{unclaimedCount > 0}}">待认领</text>
      </view>

      <!-- 说明卡片 -->
      <view class="tip-card" wx:if="{{showTip}}">
        <text class="tip-emoji">💡</text>
        <view class="tip-body">
          <text class="tip-heading">什么是影子成员？</text>
          <text class="tip-text">旅行开始前，管理员可预先添加成员名字。分账时可直接选择该成员。后期好友加入时，可认领对应的"影子身份"，一键接掌所有历史记录。</text>
        </view>
      </view>

      <!-- 影子成员卡片 -->
      <view class="shadow-member-card" wx:for="{{shadowMembers}}" wx:key="id">
        <view class="avatar avatar-shadow">
          <text class="shadow-person">👤</text>
          <view class="question-badge">?</view>
        </view>
        <view class="member-body">
          <view class="name-row">
            <text class="member-name">{{item.shadow_name}}</text>
            <text class="tag-shadow">影子成员</text>
          </view>
          <text class="shadow-subtitle" wx:if="{{!item.is_claimed}}">分享链接给 Ta，等待认领</text>
          <text class="shadow-subtitle claimed" wx:else>已认领</text>
        </view>
      </view>
    </view>

    <!-- 添加影子成员按钮 -->
    <view class="add-shadow-btn" hover-class="hover-opacity" bindtap="onAddShadow">
      <text>👥+ 添加影子成员</text>
    </view>

  </scroll-view>
</view>
