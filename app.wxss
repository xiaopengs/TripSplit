/* === 拼途记账 - 全局样式变量 === */
page {
  /* Brand */
  --color-primary: #34C759;
  --color-primary-light: #5ED47A;
  --color-primary-dark: #248A3D;
  --color-secondary: #FF9500;
  --color-accent: #5856D6;

  /* Semantic */
  --color-success: #34C759;
  --color-warning: #FFCC00;
  --color-danger: #FF3B30;
  --color-info: #007AFF;

  /* Text */
  --text-primary: #1C1C1E;
  --text-secondary: #8E8E93;
  --text-tertiary: #AEAEB2;
  --text-white: #FFFFFF;
  --text-on-primary: #FFFFFF;

  /* Backgrounds */
  --bg-primary: #F2F2F7;
  --bg-secondary: #FFFFFF;
  --bg-card: #FFFFFF;
  --bg-mask: rgba(0, 0, 0, 0.45);

  /* Borders */
  --border-color: #E5E5EA;
  --border-radius-sm: 8rpx;
  --border-radius-md: 16rpx;
  --border-radius-lg: 24rpx;
  --border-radius-xl: 32rpx;

  /* Spacing */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;

  /* Type Scale — 7 levels */
  --font-xs: 20rpx;
  --font-sm: 24rpx;
  --font-base: 28rpx;
  --font-md: 32rpx;
  --font-lg: 36rpx;
  --font-xl: 48rpx;
  --font-xxl: 64rpx;

  /* Semantic font aliases */
  --font-badge: var(--font-xs);
  --font-meta: var(--font-sm);
  --font-body: var(--font-base);
  --font-heading: var(--font-lg);
  --font-display: var(--font-xl);
  --font-hero: var(--font-xxl);
  --font-amount: var(--font-xl);

  /* Shadow-member warm palette */
  --color-shadow-bg: #FFF9E6;
  --color-shadow-border: #FFE4A0;
  --color-shadow-text: #8B6914;
  --color-shadow-text-light: #B8922A;

  /* Quick-tag warm palette */
  --color-tag-bg: #FFF8F0;
  --color-tag-border: #FFE0B2;
  --color-tag-text: #E65100;

  /* Danger-tint surface */
  --bg-danger-tint: #FFF0F0;

  /* Animation durations */
  --duration-fast: 150ms;
  --duration-normal: 250ms;
  --duration-slow: 350ms;

  /* Typography */
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'PingFang SC', sans-serif;
  font-size: var(--font-body);
  color: var(--text-primary);
  background-color: var(--bg-primary);

  /* Shadows */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  --shadow-lg: 0 8rpx 32rpx rgba(0, 0, 0, 0.14);

  /* Animation */
  --spring-curve: cubic-bezier(0.175, 0.885, 0.32, 1.275);
  --ease-out: cubic-bezier(0.25, 0.46, 0.45, 0.94);

  line-height: 1.5;
}

/* === Reset === */
view, text, image, button, input, textarea {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  background: none;
  border: none;
  line-height: inherit;
}

button::after {
  border: none;
}

/* === Utility Classes === */
.flex { display: flex; }
.flex-col { display: flex; flex-direction: column; }
.flex-row { display: flex; flex-direction: row; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-1 { flex: 1; }
.flex-wrap { flex-wrap: wrap; }

.text-center { text-align: center; }
.text-right { text-align: right; }

.text-primary { color: var(--text-primary); }
.text-secondary { color: var(--text-secondary); }
.text-success { color: var(--color-success); }
.text-danger { color: var(--color-danger); }
.text-warning { color: var(--color-warning); }

.font-bold { font-weight: 600; }
.font-amount { font-size: var(--font-amount); font-weight: 700; color: var(--color-primary); }

.mt-sm { margin-top: var(--spacing-sm); }
.mt-md { margin-top: var(--spacing-md); }
.mt-lg { margin-top: var(--spacing-lg); }
.mb-sm { margin-bottom: var(--spacing-sm); }
.mb-md { margin-bottom: var(--spacing-md); }
.p-md { padding: var(--spacing-md); }

/* Safe area bottom for FAB */
.safe-bottom { padding-bottom: calc(120rpx + env(safe-area-inset-bottom)); }

/* === Shared: Empty State === */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 48rpx 120rpx;
}

.empty-emoji {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.55;
}

.empty-emoji.large {
  font-size: 160rpx;
}

.empty-check-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: var(--bg-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.empty-check-mark {
  font-size: 72rpx;
  color: var(--text-tertiary);
  font-weight: 700;
}

.empty-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: var(--font-base);
  color: var(--text-secondary);
  margin-bottom: 40rpx;
  text-align: center;
  line-height: 1.6;
}

/* CSS 空状态图标 */
.empty-icon {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 32rpx;
  opacity: 0.4;
  position: relative;
}

.empty-icon-large {
  width: 130rpx;
  height: 130rpx;
  margin-bottom: 32rpx;
  opacity: 0.4;
  position: relative;
}

/* 空状态：无账本（旅行旗帜） */
.icon-empty-book {
  width: 100rpx;
  height: 120rpx;
  opacity: 0.3;
}
.icon-empty-book::before {
  content: '';
  position: absolute;
  left: 10rpx;
  bottom: 0;
  width: 4rpx;
  height: 100%;
  background: var(--text-tertiary);
  border-radius: 2rpx;
}
.icon-empty-book::after {
  content: '';
  position: absolute;
  left: 14rpx;
  top: 6rpx;
  width: 70rpx;
  height: 50rpx;
  background: var(--color-primary);
  opacity: 0.6;
  border-radius: 0 6rpx 6rpx 0;
}

/* 空状态：无账单（笔和纸） */
.icon-empty-bill {
  width: 90rpx;
  height: 100rpx;
  border: 4rpx solid var(--text-tertiary);
  border-radius: 6rpx;
  opacity: 0.3;
  position: relative;
}
.icon-empty-bill::before {
  content: '';
  position: absolute;
  top: 24rpx;
  left: 16rpx;
  right: 16rpx;
  height: 3rpx;
  background: var(--text-tertiary);
  box-shadow: 0 16rpx 0 var(--text-tertiary), 0 32rpx 0 var(--text-tertiary);
}
.icon-empty-bill::after {
  content: '';
  position: absolute;
  bottom: -6rpx;
  right: -6rpx;
  width: 20rpx;
  height: 3rpx;
  background: var(--text-tertiary);
  transform: rotate(-45deg);
  border-radius: 1rpx;
}

/* 空状态：无结算（循环箭头） */
.icon-empty-settle {
  width: 90rpx;
  height: 90rpx;
  opacity: 0.3;
  border: 5rpx solid var(--text-tertiary);
  border-radius: 50%;
  position: relative;
}
.icon-empty-settle::before {
  content: '';
  position: absolute;
  top: -8rpx;
  right: 14rpx;
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-bottom: 14rpx solid var(--text-tertiary);
  transform: rotate(40deg);
}
.icon-empty-settle::after {
  content: '';
  position: absolute;
  bottom: -8rpx;
  left: 14rpx;
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-top: 14rpx solid var(--text-tertiary);
  transform: rotate(40deg);
}

/* === Shared: Primary Button === */
.btn-primary {
  background: var(--color-primary) !important;
  color: var(--text-white) !important;
  font-size: var(--font-md);
  font-weight: 600;
  padding: 20rpx 60rpx;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(52, 199, 89, 0.35);
}

/* === Shared: Hover feedback === */
.hover-opacity {
  opacity: 0.7;
}

.hover-card {
  opacity: 0.85;
}

/* === Shared: Transfer Card (结算) === */
.transfer-card {
  background: white;
  border-radius: var(--border-radius-xl);
  padding: 36rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
}


.amount-row {
  display: flex; align-items: center; justify-content: space-between;
  margin: 24rpx 0 8rpx;
  padding: 20rpx 24rpx;
  background: var(--bg-primary);
  border-radius: var(--border-radius-md);
}

.amount-info { display: flex; flex-direction: column; }
.amount-total-label { font-size: var(--font-xs); color: var(--text-tertiary); }
.amount-total-value { font-size: var(--font-lg); font-weight: 700; color: var(--text-primary); }

/* === Global CSS Icon Library === */

/* Back ← — chevron left */
.icon-back {
  width: 10px;
  height: 10px;
  border-left: 2.5px solid currentColor;
  border-bottom: 2.5px solid currentColor;
  transform: rotate(45deg);
  flex-shrink: 0;
}

/* Arrow right → — chevron right */
.icon-arrow-right {
  width: 14px;
  height: 14px;
  border-right: 2.5px solid currentColor;
  border-top: 2.5px solid currentColor;
  transform: rotate(45deg);
  margin-left: -3px;
  flex-shrink: 0;
}

/* Share arrow ↗ */
.icon-share {
  width: 14px;
  height: 14px;
  border-top: 2.5px solid currentColor;
  border-right: 2.5px solid currentColor;
  position: relative;
  flex-shrink: 0;
}
.icon-share::after {
  content: '';
  position: absolute;
  top: -4px;
  right: -4px;
  width: 8px;
  height: 8px;
  border-top: 2.5px solid currentColor;
  border-right: 2.5px solid currentColor;
  transform: rotate(45deg);
}

/* Person silhouette 👤 — head + shoulders */
.icon-person {
  width: 16px;
  height: 18px;
  position: relative;
  flex-shrink: 0;
}
.icon-person::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--text-secondary);
}
.icon-person::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 14px;
  height: 8px;
  border-radius: 8px 8px 3px 3px;
  background: var(--text-secondary);
}

/* Clock 🕐 */
.icon-clock {
  width: 16px;
  height: 16px;
  border: 2px solid var(--text-secondary);
  border-radius: 50%;
  position: relative;
  flex-shrink: 0;
}
.icon-clock::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 2px;
  height: 5px;
  background: var(--text-secondary);
  transform: translate(-50%, -100%);
  border-radius: 1px;
}
.icon-clock::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 4px;
  height: 2px;
  background: var(--text-secondary);
  transform: translate(0, -50%);
  border-radius: 1px;
}

/* Camera 📷 */
.icon-camera {
  width: 18px;
  height: 15px;
  position: relative;
  flex-shrink: 0;
}
.icon-camera::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 18px;
  height: 11px;
  border: 2px solid var(--text-secondary);
  border-radius: 3px;
}
.icon-camera::after {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 6px;
  height: 3px;
  border-radius: 2px 2px 0 0;
  background: var(--text-secondary);
}

/* Pin 📍 */
.icon-pin {
  width: 14px;
  height: 18px;
  position: relative;
  flex-shrink: 0;
}
.icon-pin::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%) rotate(-45deg);
  width: 10px;
  height: 10px;
  border-radius: 50% 50% 50% 0;
  background: var(--text-secondary);
}
.icon-pin::after {
  content: '';
  position: absolute;
  top: 2px;
  left: 50%;
  transform: translateX(-50%);
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.85);
}

/* Lightbulb 💡 */
.icon-bulb {
  width: 14px;
  height: 18px;
  position: relative;
  flex-shrink: 0;
}
.icon-bulb::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: #B8922A;
}
.icon-bulb::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 6px;
  height: 5px;
  border-radius: 0 0 2px 2px;
  border: 2px solid #B8922A;
  border-top: none;
}

/* Notebook 📒 */
.icon-notebook {
  width: 20px;
  height: 24px;
  border: 2px solid var(--text-primary);
  border-radius: 2px 6px 6px 2px;
  position: relative;
  flex-shrink: 0;
}
.icon-notebook::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  height: 2px;
  background: var(--text-primary);
  transform: translateY(-50%);
}

/* Link 🔗 */
.icon-link {
  width: 18px;
  height: 10px;
  position: relative;
  flex-shrink: 0;
}
.icon-link::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 0;
  transform: translateY(-50%);
  width: 10px;
  height: 8px;
  border: 2px solid var(--color-primary);
  border-radius: 4px;
  border-right: none;
}
.icon-link::after {
  content: '';
  position: absolute;
  top: 50%;
  right: 0;
  transform: translateY(-50%);
  width: 10px;
  height: 8px;
  border: 2px solid var(--color-primary);
  border-radius: 4px;
  border-left: none;
}

/* Loading spinner ⏳ */
.icon-spinner {
  width: 48px;
  height: 48px;
  border: 4px solid var(--border-color);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  flex-shrink: 0;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}

/* Error state ✕ in circle */
.icon-error-circle {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: #FFF0F0;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  flex-shrink: 0;
}
.icon-error-circle::before,
.icon-error-circle::after {
  content: '';
  position: absolute;
  width: 28px;
  height: 3px;
  background: var(--color-danger);
  border-radius: 2px;
}
.icon-error-circle::before { transform: rotate(45deg); }
.icon-error-circle::after { transform: rotate(-45deg); }

/* Success state ✓ in circle */
.icon-success-circle {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: rgba(52, 199, 89, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  flex-shrink: 0;
}
.icon-success-circle::after {
  content: '';
  width: 22px;
  height: 12px;
  border-left: 4px solid var(--color-success);
  border-bottom: 4px solid var(--color-success);
  transform: rotate(-45deg);
  margin-top: -4px;
}

/* Smile face — for "join as self" */
.icon-smile {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background: rgba(52, 199, 89, 0.15);
  position: relative;
  flex-shrink: 0;
}
.icon-smile::before {
  content: '';
  position: absolute;
  top: 7px;
  left: 5px;
  width: 3px;
  height: 3px;
  border-radius: 50%;
  background: var(--color-primary);
  box-shadow: 8px 0 0 var(--color-primary);
}
.icon-smile::after {
  content: '';
  position: absolute;
  bottom: 5px;
  left: 50%;
  transform: translateX(-50%);
  width: 8px;
  height: 4px;
  border-radius: 0 0 8px 8px;
  border: 2px solid var(--color-primary);
  border-top: none;
}
